{
  "openapi": "3.0.3",
  "info": {
    "title": "Bitcoin API",
    "description": "Real-time Bitcoin price API.",
    "version": "0.0.1"
  },
  "components": {
    "schemas": {}
  },
  "paths": {
    "/api/ping": {
      "get": {
        "operationId": "ping",
        "summary": "Health check",
        "tags": [
          "health"
        ],
        "description": "Returns \"ok\" if the API is up and running.",
        "x-default-rate-limit": 120,
        "responses": {
          "200": {
            "description": "Default Response"
          }
        }
      }
    },
    "/api/v1/auth/forgot-password": {
      "post": {
        "operationId": "forgotPassword",
        "summary": "Request a password reset email",
        "tags": [
          "auth"
        ],
        "description": "Sends a password reset link to the given email if the account exists.",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "email": {
                    "type": "string",
                    "format": "email"
                  }
                },
                "required": [
                  "email"
                ]
              }
            }
          }
        },
        "x-default-rate-limit": 3,
        "responses": {
          "200": {
            "description": "Default Response"
          }
        }
      }
    },
    "/api/v1/auth/login": {
      "post": {
        "operationId": "login",
        "summary": "Log in with email and password",
        "tags": [
          "auth"
        ],
        "description": "Authenticates a user and sets an HttpOnly access cookie.",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "email": {
                    "type": "string"
                  },
                  "password": {
                    "type": "string"
                  }
                },
                "required": [
                  "email",
                  "password"
                ]
              }
            }
          }
        },
        "x-default-rate-limit": 10,
        "responses": {
          "200": {
            "description": "Default Response",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "email": {
                      "type": "string"
                    }
                  },
                  "required": [
                    "email"
                  ]
                }
              }
            }
          }
        }
      }
    },
    "/api/v1/auth/logout": {
      "post": {
        "operationId": "logout",
        "summary": "Log out the current user",
        "tags": [
          "auth"
        ],
        "description": "Clears the access cookie for the authenticated user.",
        "x-default-rate-limit": 30,
        "responses": {
          "200": {
            "description": "Default Response"
          }
        }
      }
    },
    "/api/v1/auth/me": {
      "get": {
        "operationId": "getMe",
        "summary": "Get current user",
        "tags": [
          "auth"
        ],
        "description": "Returns information about the currently authenticated user.",
        "x-default-rate-limit": 60,
        "responses": {
          "200": {
            "description": "Default Response",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "email": {
                      "type": "string"
                    }
                  },
                  "required": [
                    "email"
                  ]
                }
              }
            }
          }
        }
      }
    },
    "/api/v1/auth/reset-password": {
      "post": {
        "operationId": "resetPassword",
        "summary": "Reset password using a reset token",
        "tags": [
          "auth"
        ],
        "description": "Sets a new password for the user identified by the reset token from the email.",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "token": {
                    "type": "string"
                  },
                  "password": {
                    "type": "string",
                    "minLength": 8
                  }
                },
                "required": [
                  "token",
                  "password"
                ]
              }
            }
          }
        },
        "x-default-rate-limit": 3,
        "responses": {
          "200": {
            "description": "Default Response"
          }
        }
      }
    },
    "/api/v1/auth/sign-up": {
      "post": {
        "operationId": "signUp",
        "summary": "Sign up a new user",
        "tags": [
          "auth"
        ],
        "description": "Registers a new user and sends a verification email.",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "email": {
                    "type": "string",
                    "format": "email",
                    "maxLength": 255
                  },
                  "password": {
                    "type": "string",
                    "minLength": 8,
                    "maxLength": 255
                  }
                },
                "required": [
                  "email",
                  "password"
                ]
              }
            }
          }
        },
        "x-default-rate-limit": 10,
        "responses": {
          "201": {
            "description": "Default Response",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "message": {
                      "type": "string"
                    }
                  },
                  "required": [
                    "message"
                  ]
                }
              }
            }
          }
        }
      }
    },
    "/api/v1/auth/verify-email": {
      "get": {
        "operationId": "verifyEmail",
        "summary": "Verify email by token",
        "tags": [
          "auth"
        ],
        "description": "Activates the user account associated with the verification token and sets the access cookie.",
        "parameters": [
          {
            "schema": {
              "type": "string"
            },
            "in": "query",
            "name": "token",
            "required": true
          }
        ],
        "x-default-rate-limit": 5,
        "responses": {
          "200": {
            "description": "Default Response"
          }
        }
      }
    },
    "/api/v1/auth/google/callback": {
      "get": {
        "operationId": "googleCallback",
        "summary": "Google OAuth callback",
        "tags": [
          "auth"
        ],
        "description": "Handles the redirect from Google, exchanges the auth code, and sets the access cookie.",
        "parameters": [
          {
            "schema": {
              "type": "string"
            },
            "in": "query",
            "name": "code",
            "required": true
          }
        ],
        "x-default-rate-limit": 10,
        "responses": {
          "200": {
            "description": "Default Response"
          }
        }
      }
    },
    "/api/v1/auth/google/login": {
      "get": {
        "operationId": "googleLogin",
        "summary": "Start Google OAuth login flow",
        "tags": [
          "auth"
        ],
        "description": "Redirects the user to the Google OAuth consent screen.",
        "x-default-rate-limit": 10,
        "responses": {
          "200": {
            "description": "Default Response"
          }
        }
      }
    },
    "/api/v1/billing/checkout": {
      "post": {
        "operationId": "createBillingCheckoutSession",
        "summary": "Create Stripe Checkout session",
        "tags": [
          "billing"
        ],
        "description": "Creates a Stripe Checkout session for subscribing to one or more rate-limit boosts.",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "items": {
                    "type": "array",
                    "minItems": 1,
                    "items": {
                      "type": "object",
                      "properties": {
                        "routeId": {
                          "type": "string",
                          "minLength": 1
                        },
                        "tier": {
                          "type": "string",
                          "enum": [
                            "1",
                            "2",
                            "3"
                          ]
                        }
                      },
                      "required": [
                        "routeId",
                        "tier"
                      ]
                    }
                  }
                },
                "required": [
                  "items"
                ]
              }
            }
          }
        },
        "x-default-rate-limit": 10,
        "responses": {
          "200": {
            "description": "Default Response",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "url": {
                      "type": "string"
                    }
                  },
                  "required": [
                    "url"
                  ]
                }
              }
            }
          }
        }
      }
    },
    "/api/v1/billing/portal": {
      "post": {
        "operationId": "createBillingPortalSession",
        "summary": "Create Stripe Customer Portal session",
        "tags": [
          "billing"
        ],
        "description": "Creates a Stripe Customer Portal session for managing existing subscriptions.",
        "x-default-rate-limit": 10,
        "responses": {
          "200": {
            "description": "Default Response",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "url": {
                      "type": "string"
                    }
                  },
                  "required": [
                    "url"
                  ]
                }
              }
            }
          }
        }
      }
    },
    "/api/v1/billing/webhook": {
      "post": {
        "responses": {
          "200": {
            "description": "Default Response"
          }
        }
      }
    },
    "/api/v1/docs/ask-ai": {
      "post": {
        "operationId": "askAiDocs",
        "summary": "Ask AI about Bitcoin API docs",
        "tags": [
          "docs"
        ],
        "description": "Streams an AI-generated answer over Server-Sent Events. Events: `sources`, `token`, `done`. Client MUST send `Accept: text/event-stream`.",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "query": {
                    "type": "string",
                    "minLength": 1,
                    "maxLength": 1000
                  }
                },
                "required": [
                  "query"
                ]
              }
            }
          }
        },
        "x-default-rate-limit": 5,
        "responses": {
          "200": {
            "description": "Default Response"
          }
        }
      }
    },
    "/api/v1/me/api-keys/": {
      "post": {
        "operationId": "createApiKey",
        "summary": "Create API key",
        "tags": [
          "api-keys"
        ],
        "description": "Generates a new API key for the authenticated user.",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "name": {
                    "type": "string",
                    "minLength": 1,
                    "maxLength": 100
                  }
                },
                "required": [
                  "name"
                ]
              }
            }
          }
        },
        "x-default-rate-limit": 10,
        "responses": {
          "201": {
            "description": "Default Response",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "id": {
                      "type": "string"
                    },
                    "name": {
                      "type": "string"
                    },
                    "token": {
                      "type": "string"
                    },
                    "isActive": {
                      "type": "boolean"
                    },
                    "createdAt": {
                      "type": "string"
                    }
                  },
                  "required": [
                    "id",
                    "name",
                    "token",
                    "isActive",
                    "createdAt"
                  ]
                }
              }
            }
          }
        }
      },
      "get": {
        "operationId": "listApiKeys",
        "summary": "List API keys",
        "tags": [
          "api-keys"
        ],
        "description": "Returns all API keys belonging to the authenticated user.",
        "x-default-rate-limit": 60,
        "responses": {
          "200": {
            "description": "Default Response",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "apiKeys": {
                      "type": "array",
                      "items": {
                        "type": "object",
                        "properties": {
                          "id": {
                            "type": "string"
                          },
                          "name": {
                            "type": "string"
                          },
                          "token": {
                            "type": "string"
                          },
                          "isActive": {
                            "type": "boolean"
                          },
                          "createdAt": {
                            "type": "string"
                          }
                        },
                        "required": [
                          "id",
                          "name",
                          "token",
                          "isActive",
                          "createdAt"
                        ]
                      }
                    }
                  },
                  "required": [
                    "apiKeys"
                  ]
                }
              }
            }
          }
        }
      }
    },
    "/api/v1/me/api-keys/{id}": {
      "delete": {
        "operationId": "deleteApiKey",
        "summary": "Delete API key",
        "tags": [
          "api-keys"
        ],
        "description": "Permanently deletes an API key belonging to the authenticated user.",
        "parameters": [
          {
            "schema": {
              "type": "string"
            },
            "in": "path",
            "name": "id",
            "required": true
          }
        ],
        "x-default-rate-limit": 10,
        "responses": {
          "200": {
            "description": "Default Response"
          }
        }
      }
    },
    "/api/v1/me/api-keys/{id}/rotate": {
      "post": {
        "operationId": "rotateApiKey",
        "summary": "Rotate API key",
        "tags": [
          "api-keys"
        ],
        "description": "Replaces the API key with a new token; old token is invalidated.",
        "parameters": [
          {
            "schema": {
              "type": "string"
            },
            "in": "path",
            "name": "id",
            "required": true
          }
        ],
        "x-default-rate-limit": 10,
        "responses": {
          "200": {
            "description": "Default Response",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "id": {
                      "type": "string"
                    },
                    "name": {
                      "type": "string"
                    },
                    "token": {
                      "type": "string"
                    },
                    "isActive": {
                      "type": "boolean"
                    },
                    "createdAt": {
                      "type": "string"
                    }
                  },
                  "required": [
                    "id",
                    "name",
                    "token",
                    "isActive",
                    "createdAt"
                  ]
                }
              }
            }
          }
        }
      }
    },
    "/api/v1/me/boosts/": {
      "get": {
        "operationId": "listBoosts",
        "summary": "List active boosts",
        "tags": [
          "boosts"
        ],
        "description": "Returns rate-limit boosts owned by the authenticated user.",
        "x-default-rate-limit": 60,
        "responses": {
          "200": {
            "description": "Default Response",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "boosts": {
                      "type": "array",
                      "items": {
                        "type": "object",
                        "properties": {
                          "id": {
                            "type": "string"
                          },
                          "routeId": {
                            "type": "string"
                          },
                          "rateLimit": {
                            "type": "integer"
                          },
                          "expiresAt": {
                            "type": "string",
                            "nullable": true
                          },
                          "createdAt": {
                            "type": "string"
                          }
                        },
                        "required": [
                          "id",
                          "routeId",
                          "rateLimit",
                          "createdAt"
                        ]
                      }
                    }
                  },
                  "required": [
                    "boosts"
                  ]
                }
              }
            }
          }
        }
      }
    },
    "/api/v1/prices/current": {
      "get": {
        "operationId": "getCurrentPrice",
        "summary": "Get current price",
        "tags": [
          "prices"
        ],
        "description": "Returns the latest price for a given trading pair from the configured exchange. For websocket use: wscat -c ws://localhost:8000/api/v1/prices/current?symbol=btcusdt",
        "parameters": [
          {
            "schema": {
              "type": "string",
              "enum": [
                "btcusdt"
              ]
            },
            "in": "query",
            "name": "symbol",
            "required": true
          }
        ],
        "x-default-rate-limit": 20,
        "x-default-ws-connections-limit": 1,
        "responses": {
          "200": {
            "description": "Default Response",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "price": {
                      "type": "string"
                    },
                    "time": {
                      "type": "string"
                    }
                  },
                  "required": [
                    "price",
                    "time"
                  ]
                }
              }
            }
          }
        }
      }
    },
    "/mcp": {
      "post": {
        "responses": {
          "200": {
            "description": "Default Response"
          }
        }
      },
      "get": {
        "responses": {
          "200": {
            "description": "Default Response"
          }
        }
      },
      "delete": {
        "responses": {
          "200": {
            "description": "Default Response"
          }
        }
      }
    }
  },
  "tags": [
    {
      "name": "health",
      "description": "Health checks"
    },
    {
      "name": "auth",
      "description": "Authentication and account management"
    },
    {
      "name": "prices",
      "description": "Cryptocurrency prices"
    },
    {
      "name": "docs",
      "description": "Documentation search and AI assistant"
    },
    {
      "name": "api-keys",
      "description": "Manage API keys"
    },
    {
      "name": "boosts",
      "description": "Rate-limit boosts owned by the user"
    },
    {
      "name": "billing",
      "description": "Subscriptions, checkout & webhooks"
    }
  ]
}