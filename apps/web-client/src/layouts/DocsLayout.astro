---
import PublicPagesLayout from '@layouts/PublicPagesLayout.astro';

const currentPath = Astro.url.pathname.replace(/\/$/, '');

const docSections = [
  {
    heading: 'GETTING STARTED',
    groups: [
      {
        title: 'Introduction',
        href: '/docs',
      },
      {
        title: 'Quickstart Guide',
        href: '/docs/quickstart',
      },
      {
        title: 'Authentication',
        href: '/docs/authentication',
      },
    ],
  },
  {
    heading: 'ENDPOINTS',
    groups: [
      {
        title: 'Price',
        links: [{ label: 'Current Price', href: '/docs/price/current' }],
      },
    ],
  },
] as const;

function getCurrentPageTitle(): string {
  for (const section of docSections) {
    for (const group of section.groups) {
      if ('links' in group) {
        const link = group.links.find((l) => l.href.replace(/\/$/, '') === currentPath);
        if (link) return link.label;
      } else if (group.href.replace(/\/$/, '') === currentPath) {
        return group.title;
      }
    }
  }
  return 'Menu';
}

const currentPageTitle = getCurrentPageTitle();
---

<PublicPagesLayout
  title="Bitcoin API"
  description="Access comprehensive Bitcoin data with the most comfortable API. Pay only for what you use. No hidden fees."
  tawk>
  <div class="docs-layout">
    <aside class="docs-layout__sidebar">
      <nav class="docs-nav">
        {
          docSections.map((section) => (
            <div class="docs-nav__section">
              <h3 class="docs-nav__heading">{section.heading}</h3>
              <ul class="docs-nav__list">
                {section.groups.map((group) => {
                  if ('links' in group) {
                    const linkHrefs = group.links.map((l) => l.href.replace(/\/$/, ''));
                    const groupHasActive = linkHrefs.includes(currentPath);

                    return (
                      <li class="docs-nav__group">
                        <details class="docs-nav__details" open={groupHasActive}>
                          <summary class="docs-nav__summary">
                            <svg
                              class="docs-nav__icon"
                              width="16"
                              height="16"
                              viewBox="0 0 24 24"
                              fill="none"
                              stroke="currentColor"
                              stroke-width="2"
                              stroke-linecap="round"
                              stroke-linejoin="round">
                              <line x1="12" y1="1" x2="12" y2="23" />
                              <path d="M17 5H9.5a3.5 3.5 0 0 0 0 7h5a3.5 3.5 0 0 1 0 7H6" />
                            </svg>
                            <span class="docs-nav__label">{group.title}</span>
                            <svg
                              class="docs-nav__chevron"
                              width="14"
                              height="14"
                              viewBox="0 0 24 24"
                              fill="none"
                              stroke="currentColor"
                              stroke-width="2.5"
                              stroke-linecap="round"
                              stroke-linejoin="round">
                              <polyline points="9 18 15 12 9 6" />
                            </svg>
                          </summary>
                          <ul class="docs-nav__links">
                            {group.links.map((link) => {
                              const isActive = link.href.replace(/\/$/, '') === currentPath;
                              return (
                                <li>
                                  <a
                                    href={link.href}
                                    class:list={[{ 'docs-nav__link--active': isActive }]}
                                    aria-current={isActive ? 'page' : undefined}>
                                    {link.label}
                                  </a>
                                </li>
                              );
                            })}
                          </ul>
                        </details>
                      </li>
                    );
                  }

                  const isActive = group.href.replace(/\/$/, '') === currentPath;
                  return (
                    <li>
                      <a
                        href={group.href}
                        class:list={['docs-nav__page-link', { 'docs-nav__page-link--active': isActive }]}
                        aria-current={isActive ? 'page' : undefined}>
                        {group.title}
                      </a>
                    </li>
                  );
                })}
              </ul>
            </div>
          ))
        }
      </nav>
    </aside>

    <main class="docs-layout__content">
      <details class="mobile-nav" id="mobile-nav">
        <summary class="mobile-nav__trigger">
          <span>{currentPageTitle}</span>
          <svg
            class="mobile-nav__chevron"
            width="16"
            height="16"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2.5"
            stroke-linecap="round"
            stroke-linejoin="round">
            <polyline points="6 9 12 15 18 9" />
          </svg>
        </summary>
        <nav class="mobile-nav__content">
          {
            docSections.map((section) => (
              <div class="mobile-nav__section">
                <h3 class="mobile-nav__heading">{section.heading}</h3>
                <ul class="mobile-nav__list">
                  {section.groups.map((group) => {
                    if ('links' in group) {
                      return group.links.map((link) => {
                        const isActive = link.href.replace(/\/$/, '') === currentPath;
                        return (
                          <li>
                            <a
                              href={link.href}
                              class:list={['mobile-nav__link', { 'mobile-nav__link--active': isActive }]}
                              aria-current={isActive ? 'page' : undefined}>
                              {link.label}
                            </a>
                          </li>
                        );
                      });
                    }

                    const isActive = group.href.replace(/\/$/, '') === currentPath;
                    return (
                      <li>
                        <a
                          href={group.href}
                          class:list={['mobile-nav__link', { 'mobile-nav__link--active': isActive }]}
                          aria-current={isActive ? 'page' : undefined}>
                          {group.title}
                        </a>
                      </li>
                    );
                  })}
                </ul>
              </div>
            ))
          }
        </nav>
      </details>

      <details class="mobile-toc" id="mobile-toc">
        <summary class="mobile-toc__trigger">
          <span>On this page</span>
          <svg
            class="mobile-toc__chevron"
            width="16"
            height="16"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2.5"
            stroke-linecap="round"
            stroke-linejoin="round">
            <polyline points="6 9 12 15 18 9" />
          </svg>
        </summary>
        <nav class="mobile-toc__content">
          <ul class="mobile-toc__list" id="mobile-toc-list"></ul>
        </nav>
      </details>

      <slot />
    </main>

    <aside class="docs-toc">
      <nav class="docs-toc__nav">
        <h4 class="docs-toc__title">On this page</h4>
        <ul class="docs-toc__list" id="toc-list"></ul>
      </nav>

      <div class="docs-sidebar-card">
        <h4 class="docs-sidebar-card__title">Need help?</h4>
        <p class="docs-sidebar-card__text">Our developer team is online to help you integrate.</p>
        <a href="/contact" class="docs-sidebar-card__btn docs-sidebar-card__btn--outline">Chat Support</a>
      </div>

      <div class="docs-sidebar-card">
        <h4 class="docs-sidebar-card__title">Connect AI</h4>
        <p class="docs-sidebar-card__text">
          Connect via MCP to enable AI agents to navigate and understand our documentation directly in your IDE.
        </p>
        <a href="/docs/quickstart" class="docs-sidebar-card__btn docs-sidebar-card__btn--primary">Setup MCP</a>
      </div>

      <div class="docs-sidebar-card">
        <h4 class="docs-sidebar-card__title">Support Us</h4>
        <p class="docs-sidebar-card__text">
          Your donations help the project grow and cover server costs. Every contribution makes a difference.
        </p>
        <a href="/pricing" class="docs-sidebar-card__btn docs-sidebar-card__btn--primary">Donate Now</a>
      </div>
    </aside>
  </div>
</PublicPagesLayout>

<style>
  .docs-layout {
    display: grid;
    grid-template-columns: minmax(200px, 260px) minmax(0, 1fr) 220px;
    gap: 2rem;
    width: 100%;
    max-width: var(--container-max);
    margin: 0 auto;
    padding: 2rem 1rem;
  }

  /* ── Left sidebar ── */

  .docs-layout__sidebar {
    position: sticky;
    top: 6rem;
    align-self: start;
    max-height: calc(100vh - 8rem);
    overflow-y: auto;
  }

  .docs-nav__section {
    margin-bottom: 1.5rem;
  }

  .docs-nav__heading {
    font-size: 0.6875rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--color-text-muted);
    margin: 0 0 0.5rem;
    padding: 0;
  }

  .docs-nav__list {
    list-style: none;
    margin: 0;
    padding: 0;
  }

  .docs-nav__group {
    margin-bottom: 0.25rem;
  }

  .docs-nav__details {
    border-radius: 4px;
  }

  .docs-nav__summary {
    display: flex;
    align-items: center;
    gap: 0.4rem;
    padding: 0.5rem 0.75rem;
    font-size: 0.9375rem;
    font-weight: 600;
    line-height: 1;
    letter-spacing: -0.01em;
    cursor: pointer;
    list-style: none;
    user-select: none;
    color: var(--color-text);
    border-radius: 8px;
    transition:
      background-color 0.15s,
      color 0.15s;
  }

  .docs-nav__summary:hover {
    background: rgba(9, 131, 253, 0.06);
    color: var(--color-accent);
  }

  .docs-nav__summary:hover .docs-nav__icon,
  .docs-nav__summary:hover .docs-nav__chevron {
    color: var(--color-accent);
  }

  .docs-nav__summary::-webkit-details-marker {
    display: none;
  }

  .docs-nav__icon {
    flex-shrink: 0;
    display: block;
    color: var(--color-accent);
    opacity: 0.85;
    transition: color 0.15s;
  }

  .docs-nav__label {
    flex: 1;
    display: inline-flex;
    align-items: center;
    line-height: 1;
  }

  .docs-nav__chevron {
    flex-shrink: 0;
    color: var(--color-text-muted);
    opacity: 0.7;
    transition:
      transform 0.2s ease,
      color 0.15s;
  }

  .docs-nav__details[open] > .docs-nav__summary > .docs-nav__chevron {
    transform: rotate(90deg);
  }

  .docs-nav__links {
    list-style: none;
    margin: 0;
    padding: 0 0 0 0.5rem;
  }

  .docs-nav__links a {
    display: block;
    padding: 0.3rem 0.75rem;
    margin-left: 1rem;
    color: var(--color-text-muted);
    text-decoration: none;
    font-size: 0.875rem;
    border-left: 2px solid transparent;
    border-radius: 0 4px 4px 0;
    transition:
      background-color 0.15s,
      color 0.15s,
      border-color 0.15s;
  }

  .docs-nav__links a:hover {
    color: var(--color-text);
    background: rgba(0, 0, 0, 0.04);
  }

  .docs-nav__link--active {
    color: var(--color-accent) !important;
    background: rgba(9, 131, 253, 0.08) !important;
    border-left-color: var(--color-accent) !important;
    font-weight: 500;
  }

  .docs-nav__page-link {
    display: block;
    padding: 0.4rem 0.75rem;
    color: var(--color-text-muted);
    text-decoration: none;
    font-size: 0.875rem;
    border-radius: 6px;
    transition:
      background-color 0.15s,
      color 0.15s;
  }

  .docs-nav__page-link:hover {
    color: var(--color-text);
    background: rgba(0, 0, 0, 0.04);
  }

  .docs-nav__page-link--active {
    color: var(--color-accent) !important;
    background: rgba(9, 131, 253, 0.08) !important;
    font-weight: 500;
  }

  /* ── Right sidebar (TOC + cards) ── */

  .docs-toc {
    position: sticky;
    top: 6rem;
    align-self: start;
    max-height: calc(100vh - 8rem);
    overflow-y: auto;
  }

  .docs-toc__title {
    margin: 0 0 0.75rem;
    font-size: 0.8125rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.04em;
    color: var(--color-text);
  }

  .docs-toc__list {
    list-style: none;
    margin: 0;
    padding: 0;
    border-left: 2px solid #eee;
  }

  .docs-toc__list :global(li) {
    margin: 0;
  }

  .docs-toc__list :global(a) {
    display: block;
    padding: 0.25rem 0 0.25rem 0.75rem;
    font-size: 0.8125rem;
    color: var(--color-text-muted);
    text-decoration: none;
    border-left: 2px solid transparent;
    margin-left: -2px;
    transition:
      color 0.15s,
      border-color 0.15s;
  }

  .docs-toc__list :global(a:hover) {
    color: var(--color-text);
  }

  .docs-toc__list :global(a.toc-active) {
    color: var(--color-accent);
    border-left-color: var(--color-accent);
  }

  .docs-toc__list :global(a[data-level='3']) {
    padding-left: 1.5rem;
  }

  /* ── Sidebar cards ── */

  .docs-sidebar-card {
    margin-top: 1.5rem;
    padding: 1.25rem;
    background: #f8fafc;
    border: 1px solid #e2e8f0;
    border-radius: 10px;
  }

  .docs-sidebar-card__title {
    font-size: 0.875rem;
    font-weight: 600;
    color: var(--color-text);
    margin: 0 0 0.5rem;
  }

  .docs-sidebar-card__text {
    font-size: 0.8125rem;
    color: var(--color-text-muted);
    line-height: 1.5;
    margin: 0 0 0.75rem;
  }

  .docs-sidebar-card__btn {
    display: block;
    width: 100%;
    text-align: center;
    padding: 0.5rem 1rem;
    border-radius: 6px;
    font-size: 0.8125rem;
    font-weight: 500;
    text-decoration: none;
    transition:
      background-color 0.15s,
      color 0.15s;
  }

  .docs-sidebar-card__btn--outline {
    border: 1px solid #e2e8f0;
    color: var(--color-text);
    background: white;
  }

  .docs-sidebar-card__btn--outline:hover {
    border-color: var(--color-accent);
    color: var(--color-accent);
  }

  .docs-sidebar-card__btn--primary {
    background: var(--color-accent);
    color: white;
    border: none;
  }

  .docs-sidebar-card__btn--primary:hover {
    background: var(--color-accent-hover);
  }

  /* ── Content ── */

  .docs-layout__content {
    min-width: 0;
  }

  /* ── Mobile navigation dropdowns ── */

  .mobile-nav,
  .mobile-toc {
    display: none;
  }

  .mobile-nav__trigger,
  .mobile-toc__trigger {
    display: flex;
    align-items: center;
    justify-content: space-between;
    width: 100%;
    padding: 0.625rem 0.875rem;
    font-size: 0.875rem;
    font-weight: 500;
    color: var(--color-text);
    background: #f8fafc;
    border: 1px solid #e2e8f0;
    border-radius: 8px;
    cursor: pointer;
    list-style: none;
    user-select: none;
    transition: border-color 0.15s;
  }

  .mobile-nav__trigger::-webkit-details-marker,
  .mobile-toc__trigger::-webkit-details-marker {
    display: none;
  }

  .mobile-nav__trigger:hover,
  .mobile-toc__trigger:hover {
    border-color: var(--color-accent);
  }

  .mobile-nav__chevron,
  .mobile-toc__chevron {
    flex-shrink: 0;
    color: var(--color-text-muted);
    transition: transform 0.2s ease;
  }

  .mobile-nav[open] > .mobile-nav__trigger > .mobile-nav__chevron,
  .mobile-toc[open] > .mobile-toc__trigger > .mobile-toc__chevron {
    transform: rotate(180deg);
  }

  .mobile-nav__content,
  .mobile-toc__content {
    padding: 0.5rem 0;
    border: 1px solid #e2e8f0;
    border-top: none;
    border-radius: 0 0 8px 8px;
    background: white;
    margin-top: -1px;
  }

  .mobile-nav__section {
    padding: 0.5rem 0;
  }

  .mobile-nav__section:first-child {
    padding-top: 0;
  }

  .mobile-nav__heading {
    font-size: 0.6875rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--color-text-muted);
    margin: 0;
    padding: 0.25rem 0.875rem;
  }

  .mobile-nav__list {
    list-style: none;
    margin: 0;
    padding: 0;
  }

  .mobile-nav__link {
    display: block;
    padding: 0.4rem 0.875rem;
    color: var(--color-text-muted);
    text-decoration: none;
    font-size: 0.875rem;
    transition:
      background-color 0.15s,
      color 0.15s;
  }

  .mobile-nav__link:hover {
    color: var(--color-text);
    background: rgba(0, 0, 0, 0.04);
  }

  .mobile-nav__link--active {
    color: var(--color-accent) !important;
    background: rgba(9, 131, 253, 0.08) !important;
    font-weight: 500;
  }

  .mobile-toc__list {
    list-style: none;
    margin: 0;
    padding: 0;
  }

  .mobile-toc__list :global(a) {
    display: block;
    padding: 0.35rem 0.875rem;
    font-size: 0.8125rem;
    color: var(--color-text-muted);
    text-decoration: none;
    transition:
      background-color 0.15s,
      color 0.15s;
  }

  .mobile-toc__list :global(a:hover) {
    color: var(--color-text);
    background: rgba(0, 0, 0, 0.04);
  }

  .mobile-toc__list :global(a[data-level='3']) {
    padding-left: 1.75rem;
  }

  /* ── Responsive ── */

  @media (max-width: 1024px) {
    .docs-layout {
      grid-template-columns: minmax(200px, 240px) minmax(0, 1fr);
    }

    .docs-toc {
      display: none;
    }

    .mobile-toc {
      display: block;
      margin-bottom: 1.5rem;
    }
  }

  @media (max-width: 768px) {
    .docs-layout {
      grid-template-columns: 1fr;
    }

    .docs-layout__sidebar {
      display: none;
    }

    .mobile-nav {
      display: block;
      margin-bottom: 0.75rem;
    }

    .mobile-toc {
      display: block;
      margin-bottom: 1.5rem;
    }
  }
</style>

<script>
  function buildTOC() {
    const content = document.querySelector('.docs-layout__content');
    const tocList = document.getElementById('toc-list');
    const mobileTocList = document.getElementById('mobile-toc-list');
    const mobileToc = document.getElementById('mobile-toc');
    if (!content || !tocList) return;

    const headings = content.querySelectorAll<HTMLHeadingElement>('h2, h3');
    if (headings.length === 0) {
      const tocNav = tocList.closest<HTMLElement>('.docs-toc__nav');
      if (tocNav) tocNav.style.display = 'none';
      if (mobileToc) mobileToc.style.display = 'none';
      return;
    }

    for (const heading of headings) {
      if (!heading.id) {
        heading.id = heading
          .textContent!.trim()
          .toLowerCase()
          .replace(/[^\w\s-]/g, '')
          .replace(/\s+/g, '-');
      }

      const li = document.createElement('li');
      const a = document.createElement('a');
      a.href = `#${heading.id}`;
      a.textContent = heading.textContent!.trim();
      a.dataset.level = heading.tagName === 'H3' ? '3' : '2';
      li.appendChild(a);
      tocList.appendChild(li);

      if (mobileTocList) {
        mobileTocList.appendChild(li.cloneNode(true));
      }
    }

    const tocLinks = tocList.querySelectorAll<HTMLAnchorElement>('a');

    const observer = new IntersectionObserver(
      (entries) => {
        for (const entry of entries) {
          if (entry.isIntersecting) {
            tocLinks.forEach((link) => link.classList.remove('toc-active'));
            const active = tocList.querySelector(`a[href="#${entry.target.id}"]`);
            if (active) active.classList.add('toc-active');
          }
        }
      },
      { rootMargin: '0px 0px -70% 0px', threshold: 0.1 }
    );

    headings.forEach((h) => observer.observe(h));

    if (mobileTocList) {
      const mobileLinks = mobileTocList.querySelectorAll<HTMLAnchorElement>('a');
      for (const link of mobileLinks) {
        link.addEventListener('click', () => {
          mobileToc?.removeAttribute('open');
        });
      }
    }
  }

  buildTOC();
</script>
