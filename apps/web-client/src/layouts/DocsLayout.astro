---
import PublicPagesLayout from '@layouts/PublicPagesLayout.astro';
import { getEntry } from 'astro:content';
import { getRelativeLocaleUrl } from 'astro:i18n';
import { type Locale } from 'src/types';
import assert from 'node:assert';

const lang = Astro.currentLocale as Locale;
const uiCollection = await getEntry('ui', lang);
assert(uiCollection?.data, 'UI collection not found');
const uiContent = uiCollection.data;

const currentPath = Astro.url.pathname.replace(/\/$/, '');

const docGroups = [
  {
    title: 'Price',
    links: [{ label: 'Current Price', href: '/docs/price/current' }],
  },
] as const;
---

<PublicPagesLayout title={uiContent.defaultTitle} description={uiContent.defaultDescription}>
  <div class="docs-layout">
    <aside class="docs-layout__sidebar">
      <nav class="docs-nav">
        <div class="docs-nav__actions">
          <button type="button" class="docs-nav__toggle" data-action="expand" aria-label="Expand all">
            Expand all
          </button>
          <button type="button" class="docs-nav__toggle" data-action="collapse" aria-label="Collapse all">
            Collapse all
          </button>
        </div>
        <ul class="docs-nav__list">
          {
            docGroups.map((group) => {
              const linkHrefs = group.links.map((l) => getRelativeLocaleUrl(lang, l.href).replace(/\/$/, ''));
              const groupHasActive = linkHrefs.includes(currentPath);

              return (
                <li class="docs-nav__group">
                  <details class="docs-nav__details" open={groupHasActive}>
                    <summary class="docs-nav__summary">{group.title}</summary>
                    <ul class="docs-nav__links">
                      {group.links.map((link) => {
                        const href = getRelativeLocaleUrl(lang, link.href);
                        const isActive = href.replace(/\/$/, '') === currentPath;
                        return (
                          <li>
                            <a
                              href={href}
                              class:list={[{ 'docs-nav__link--active': isActive }]}
                              aria-current={isActive ? 'page' : undefined}
                            >
                              {link.label}
                            </a>
                          </li>
                        );
                      })}
                    </ul>
                  </details>
                </li>
              );
            })
          }
        </ul>
      </nav>
    </aside>

    <main class="docs-layout__content">
      <slot />
    </main>

    <aside class="docs-toc">
      <nav class="docs-toc__nav">
        <h4 class="docs-toc__title">On this page</h4>
        <ul class="docs-toc__list" id="toc-list"></ul>
      </nav>
    </aside>
  </div>
</PublicPagesLayout>

<style>
  .docs-layout {
    display: grid;
    grid-template-columns: minmax(200px, 260px) minmax(0, 1fr) 220px;
    gap: 2rem;
    width: 100%;
    max-width: var(--container-max);
    margin: 0 auto;
    padding: 2rem 1rem;
  }

  /* ── Left sidebar ── */

  .docs-layout__sidebar {
    position: sticky;
    top: 2rem;
    align-self: start;
    max-height: calc(100vh - 4rem);
    overflow-y: auto;
  }

  .docs-nav__actions {
    display: flex;
    gap: 0.5rem;
    margin-bottom: 1rem;
  }

  .docs-nav__toggle {
    padding: 0.25rem 0.5rem;
    font-size: 0.8125rem;
    background: none;
    border: 1px solid #ddd;
    border-radius: 4px;
    cursor: pointer;
    color: var(--color-text-muted);
  }

  .docs-nav__toggle:hover {
    color: var(--color-text);
    border-color: var(--color-text-muted);
  }

  .docs-nav__list {
    list-style: none;
    margin: 0;
    padding: 0;
  }

  .docs-nav__group {
    margin-bottom: 0.25rem;
  }

  .docs-nav__details {
    border-radius: 4px;
  }

  .docs-nav__summary {
    padding: 0.5rem 0;
    font-size: 0.875rem;
    font-weight: 600;
    cursor: pointer;
    list-style: none;
    user-select: none;
    color: var(--color-text);
  }

  .docs-nav__summary::-webkit-details-marker {
    display: none;
  }

  .docs-nav__summary::before {
    content: '▶ ';
    display: inline-block;
    font-size: 0.6em;
    margin-right: 0.35rem;
    opacity: 0.5;
    transition: transform 0.15s;
  }

  .docs-nav__details[open] > .docs-nav__summary::before {
    transform: rotate(90deg);
  }

  .docs-nav__links {
    list-style: none;
    margin: 0;
    padding: 0 0 0 0.25rem;
  }

  .docs-nav__links a {
    display: block;
    padding: 0.3rem 0.75rem;
    margin-left: 0.5rem;
    color: var(--color-text-muted);
    text-decoration: none;
    font-size: 0.875rem;
    border-left: 2px solid transparent;
    border-radius: 0 4px 4px 0;
    transition:
      background-color 0.15s,
      color 0.15s,
      border-color 0.15s;
  }

  .docs-nav__links a:hover {
    color: var(--color-text);
    background: rgba(0, 0, 0, 0.04);
  }

  .docs-nav__link--active {
    color: var(--color-accent) !important;
    background: rgba(249, 115, 22, 0.08) !important;
    border-left-color: var(--color-accent) !important;
    font-weight: 500;
  }

  /* ── Right sidebar (TOC) ── */

  .docs-toc {
    position: sticky;
    top: 2rem;
    align-self: start;
    max-height: calc(100vh - 4rem);
    overflow-y: auto;
  }

  .docs-toc__title {
    margin: 0 0 0.75rem;
    font-size: 0.8125rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.04em;
    color: var(--color-text);
  }

  .docs-toc__list {
    list-style: none;
    margin: 0;
    padding: 0;
    border-left: 2px solid #eee;
  }

  .docs-toc__list :global(li) {
    margin: 0;
  }

  .docs-toc__list :global(a) {
    display: block;
    padding: 0.25rem 0 0.25rem 0.75rem;
    font-size: 0.8125rem;
    color: var(--color-text-muted);
    text-decoration: none;
    border-left: 2px solid transparent;
    margin-left: -2px;
    transition:
      color 0.15s,
      border-color 0.15s;
  }

  .docs-toc__list :global(a:hover) {
    color: var(--color-text);
  }

  .docs-toc__list :global(a.toc-active) {
    color: var(--color-accent);
    border-left-color: var(--color-accent);
  }

  .docs-toc__list :global(a[data-level="3"]) {
    padding-left: 1.5rem;
  }

  /* ── Content ── */

  .docs-layout__content {
    min-width: 0;
  }

  /* ── Responsive ── */

  @media (max-width: 1024px) {
    .docs-layout {
      grid-template-columns: minmax(200px, 240px) minmax(0, 1fr);
    }

    .docs-toc {
      display: none;
    }
  }

  @media (max-width: 768px) {
    .docs-layout {
      grid-template-columns: 1fr;
    }

    .docs-layout__sidebar {
      position: static;
      max-height: none;
    }
  }
</style>

<script>
  document.querySelectorAll<HTMLButtonElement>('.docs-nav__toggle').forEach((btn) => {
    btn.addEventListener('click', () => {
      const details = document.querySelectorAll<HTMLDetailsElement>('.docs-nav__details');
      const expand = btn.dataset.action === 'expand';
      details.forEach((el) => {
        el.open = expand;
      });
    });
  });

  function buildTOC() {
    const content = document.querySelector('.docs-layout__content');
    const tocList = document.getElementById('toc-list');
    if (!content || !tocList) return;

    const headings = content.querySelectorAll<HTMLHeadingElement>('h2, h3');
    if (headings.length === 0) {
      const tocNav = tocList.closest<HTMLElement>('.docs-toc');
      if (tocNav) tocNav.style.display = 'none';
      return;
    }

    for (const heading of headings) {
      if (!heading.id) {
        heading.id = heading.textContent!
          .trim()
          .toLowerCase()
          .replace(/[^\w\s-]/g, '')
          .replace(/\s+/g, '-');
      }

      const li = document.createElement('li');
      const a = document.createElement('a');
      a.href = `#${heading.id}`;
      a.textContent = heading.textContent!.trim();
      a.dataset.level = heading.tagName === 'H3' ? '3' : '2';
      li.appendChild(a);
      tocList.appendChild(li);
    }

    const tocLinks = tocList.querySelectorAll<HTMLAnchorElement>('a');

    const observer = new IntersectionObserver(
      (entries) => {
        for (const entry of entries) {
          if (entry.isIntersecting) {
            tocLinks.forEach((link) => link.classList.remove('toc-active'));
            const active = tocList.querySelector(`a[href="#${entry.target.id}"]`);
            if (active) active.classList.add('toc-active');
          }
        }
      },
      { rootMargin: '0px 0px -70% 0px', threshold: 0.1 },
    );

    headings.forEach((h) => observer.observe(h));
  }

  buildTOC();
</script>
