---
import '@styles/global.css';
import Logo from '@icons/Logo.astro';
import SidebarUser from '@components/layout/SidebarUser.vue';
import { CircleUserRound, Home, Settings, LogOut } from '@lucide/astro';

interface Props {
  title?: string;
  description?: string;
  activeNav?: string;
}

const {
  title = 'Profile — Bitcoin API',
  description = 'Manage your Bitcoin API account.',
  activeNav = 'home',
} = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width" />
    <meta name="description" content={description} />
    <title>{title}</title>
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" href="/favicon.ico" />
    <link
      href="https://fonts.googleapis.com/css2?family=Inter:wght@100;200;300;400;500;600;700;800;900&display=swap"
      rel="stylesheet"
    />
  </head>
  <body>
    <div class="profile-shell">
      <header class="mobile-header">
        <a href="/" class="sidebar-brand">
          <div class="sidebar-logo">
            <Logo class="w-[22px] h-[22px] text-white" />
          </div>
          <span class="sidebar-brand-name">Bitcoin API</span>
        </a>
        <button class="menu-toggle" id="menu-toggle" aria-label="Toggle menu">
          <svg
            width="24"
            height="24"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2"
            stroke-linecap="round"
            stroke-linejoin="round">
            <line x1="3" y1="6" x2="21" y2="6"></line>
            <line x1="3" y1="12" x2="21" y2="12"></line>
            <line x1="3" y1="18" x2="21" y2="18"></line>
          </svg>
        </button>
      </header>

      <div class="sidebar-overlay" id="sidebar-overlay"></div>

      <aside class="sidebar" id="sidebar">
        <a href="/" class="sidebar-brand">
          <div class="sidebar-logo">
            <Logo class="w-[22px] h-[22px] text-white" />
          </div>
          <span class="sidebar-brand-name">Bitcoin API</span>
        </a>

        <div class="sidebar-user">
          <div class="sidebar-avatar">
            <CircleUserRound size={36} color="#0983FD" />
          </div>
          <SidebarUser client:load />
        </div>

        <nav class="sidebar-nav">
          <span class="sidebar-nav-label">Menu</span>
          <a href="/profile/home" class:list={['sidebar-nav-item', { active: activeNav === 'home' }]}>
            <Home size={18} />
            <span>Home</span>
          </a>
          <a href="/profile/settings" class:list={['sidebar-nav-item', { active: activeNav === 'settings' }]}>
            <Settings size={18} />
            <span>Settings</span>
          </a>
        </nav>

        <div class="sidebar-bottom">
          <a href="/authorization/sign-in" id="logout-btn" class="sidebar-nav-item">
            <LogOut size={18} />
            <span>Log out</span>
          </a>
        </div>
      </aside>

      <main class="main-content">
        <slot />
      </main>
    </div>
  </body>
</html>

<script>
  import { userStore, logout, fetchUser } from '@stores/auth';
  await fetchUser();
  userStore.subscribe((user) => {
    if (!user) {
      window.location.href = '/authorization/sign-in';
    }
  });

  document.getElementById('logout-btn')?.addEventListener('click', async (e) => {
    e.preventDefault();
    await logout();
    window.location.href = '/authorization/sign-in';
  });

  const menuToggle = document.getElementById('menu-toggle');
  const sidebar = document.getElementById('sidebar');
  const overlay = document.getElementById('sidebar-overlay');

  function toggleSidebar() {
    sidebar?.classList.toggle('open');
    overlay?.classList.toggle('open');
  }

  menuToggle?.addEventListener('click', toggleSidebar);
  overlay?.addEventListener('click', toggleSidebar);
</script>

<style>
  /* ── Shell ── */
  .profile-shell {
    display: flex;
    min-height: 100vh;
  }

  /* ── Sidebar ── */
  .sidebar {
    width: 260px;
    min-width: 260px;
    background: #fff;
    border-right: 1px solid #dee1e6;
    display: flex;
    flex-direction: column;
    padding: 24px 16px;
  }

  .sidebar-brand {
    display: flex;
    align-items: center;
    gap: 10px;
    text-decoration: none;
    margin-bottom: 32px;
  }

  .sidebar-logo {
    width: 32px;
    height: 32px;
    background: #0983fd;
    border-radius: 8px;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .sidebar-brand-name {
    font-size: 18px;
    font-weight: 700;
    color: #0983fd;
  }

  /* ── User block ── */
  .sidebar-user {
    display: flex;
    align-items: center;
    gap: 10px;
    padding: 12px;
    background: #f5f7fa;
    border-radius: 10px;
    margin-bottom: 28px;
  }

  .sidebar-avatar {
    flex-shrink: 0;
    display: flex;
  }

  /* ── Navigation ── */
  .sidebar-nav {
    display: flex;
    flex-direction: column;
    gap: 4px;
  }

  .sidebar-nav-label {
    font-size: 11px;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    color: #9095a1;
    padding: 0 12px;
    margin-bottom: 8px;
  }

  .sidebar-nav-item {
    display: flex;
    align-items: center;
    gap: 10px;
    padding: 10px 12px;
    border-radius: 8px;
    font-size: 14px;
    font-weight: 500;
    color: #565d6d;
    text-decoration: none;
    transition:
      background 0.15s,
      color 0.15s;
  }

  .sidebar-nav-item:hover {
    background: #f0f2f5;
    color: #171a1f;
  }

  .sidebar-nav-item.active {
    background: #eff6ff;
    color: #0983fd;
    font-weight: 600;
  }

  /* ── Sidebar bottom ── */
  .sidebar-bottom {
    margin-top: auto;
    padding-top: 16px;
    border-top: 1px solid #dee1e6;
  }

  /* ── Main content ── */
  .main-content {
    flex: 1;
    background: #f5f7fa;
    padding: 40px;
    overflow-y: auto;
  }

  /* ── Mobile header ── */
  .mobile-header {
    display: none;
  }

  .menu-toggle {
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 8px;
    border: none;
    background: transparent;
    border-radius: 8px;
    cursor: pointer;
    color: #565d6d;
  }

  .menu-toggle:hover {
    background: #f0f2f5;
  }

  .sidebar-overlay {
    display: none;
  }

  /* ── Responsive ── */
  @media (max-width: 768px) {
    .profile-shell {
      flex-direction: column;
    }

    .mobile-header {
      display: flex;
      align-items: center;
      justify-content: space-between;
      padding: 12px 16px;
      background: #fff;
      border-bottom: 1px solid #dee1e6;
      position: sticky;
      top: 0;
      z-index: 20;
    }

    .mobile-header .sidebar-brand {
      margin-bottom: 0;
    }

    .sidebar {
      position: fixed;
      top: 0;
      left: 0;
      bottom: 0;
      z-index: 30;
      transform: translateX(-100%);
      transition: transform 0.25s ease;
    }

    .sidebar.open {
      transform: translateX(0);
    }

    .sidebar-overlay {
      display: none;
      position: fixed;
      inset: 0;
      background: rgba(0, 0, 0, 0.3);
      z-index: 25;
    }

    .sidebar-overlay.open {
      display: block;
    }

    .main-content {
      padding: 24px 16px;
    }
  }
</style>
