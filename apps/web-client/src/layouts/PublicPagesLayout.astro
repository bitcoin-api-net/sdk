---
import '@styles/global.css';
import Logo from '@icons/Logo.astro';
import HeaderAuth from '@components/layout/HeaderAuth.vue';
import { Box, BookOpen, CreditCard } from '@lucide/astro';
interface Props {
  title?: string;
  description?: string;
  tawk?: boolean;
}

const {
  title = 'Bitcoin API',
  description = 'Access comprehensive Bitcoin data with the most comfortable API. Pay only for what you use. No hidden fees.',
  tawk = false,
} = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width" />
    <meta name="description" content={description} />
    <meta name="generator" content={Astro.generator} />
    <title>{title}</title>
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" href="/favicon.ico" />
    <link
      href="https://fonts.googleapis.com/css2?family=Inter:wght@100;200;300;400;500;600;700;800;900&family=Sora:wght@100;200;300;400;500;600;700;800;900&display=swap"
      rel="stylesheet"
    />
  </head>
  <body class="bg-white">
    <header class="sticky top-0 z-50 w-full bg-white/80 backdrop-blur-md border-b border-[#dee1e6]">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 h-20 flex items-center justify-between">
        <a href="/" class="flex items-center gap-3">
          <div class="w-8 h-8 bg-[#0983FD] rounded-md flex items-center justify-center">
            <Logo class="w-[22px] h-[22px] text-white" />
          </div>
          <span class="text-xl font-bold text-[#0983FD]">Bitcoin API</span>
        </a>

        <nav class="hidden md:flex items-center gap-8">
          <a href="/products" class="text-sm font-medium hover:text-[#0983FD]">Products</a>
          <a href="/docs" class="text-sm font-medium hover:text-[#0983FD]">Documentation</a>
          <a href="/pricing" class="text-sm font-medium hover:text-[#0983FD]">Pricing</a>
        </nav>

        <div class="hidden md:block">
          <HeaderAuth client:load />
        </div>

        <button
          id="mobile-menu-btn"
          class="md:hidden flex items-center justify-center p-2 rounded-lg hover:bg-black/5 transition-colors"
          aria-label="Open menu"
        >
          <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <line x1="3" y1="6" x2="21" y2="6" />
            <line x1="3" y1="12" x2="21" y2="12" />
            <line x1="3" y1="18" x2="21" y2="18" />
          </svg>
        </button>
      </div>
    </header>

    <div id="mobile-sidebar-overlay" class="fixed inset-0 bg-black/30 z-[60] hidden opacity-0 transition-opacity duration-300"></div>
    <aside id="mobile-sidebar" class="fixed top-0 right-0 bottom-0 w-72 bg-white z-[70] shadow-xl translate-x-full transition-transform duration-300 flex flex-col">
      <div class="flex items-center justify-between px-5 h-20 border-b border-[#dee1e6]">
        <a href="/" class="flex items-center gap-3">
          <div class="w-8 h-8 bg-[#0983FD] rounded-md flex items-center justify-center">
            <Logo class="w-[22px] h-[22px] text-white" />
          </div>
          <span class="text-xl font-bold text-[#0983FD]">Bitcoin API</span>
        </a>
        <button
          id="mobile-menu-close"
          class="flex items-center justify-center p-2 rounded-lg hover:bg-black/5 transition-colors"
          aria-label="Close menu"
        >
          <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <line x1="18" y1="6" x2="6" y2="18" />
            <line x1="6" y1="6" x2="18" y2="18" />
          </svg>
        </button>
      </div>

      <div id="mobile-sidebar-auth" class="px-4 pt-4 pb-2">
        <HeaderAuth variant="sidebar" client:load />
      </div>

      <nav class="flex flex-col gap-1 px-4 py-4 border-t border-[#dee1e6]">
        <a href="/products" class="flex items-center gap-3 px-3 py-2.5 text-sm font-medium text-[#565d6d] rounded-lg hover:bg-black/5 hover:text-[#0983FD] transition-colors">
          <Box size={18} class="flex-shrink-0" />
          <span>Products</span>
        </a>
        <a href="/docs" class="flex items-center gap-3 px-3 py-2.5 text-sm font-medium text-[#565d6d] rounded-lg hover:bg-black/5 hover:text-[#0983FD] transition-colors">
          <BookOpen size={18} class="flex-shrink-0" />
          <span>Documentation</span>
        </a>
        <a href="/pricing" class="flex items-center gap-3 px-3 py-2.5 text-sm font-medium text-[#565d6d] rounded-lg hover:bg-black/5 hover:text-[#0983FD] transition-colors">
          <CreditCard size={18} class="flex-shrink-0" />
          <span>Pricing</span>
        </a>
      </nav>
    </aside>

    <slot />

    <footer class="bg-[#fafafb] pt-20 pb-10 border-t border-[#dee1e6]">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-12 mb-16">
          <div class="lg:col-span-1">
            <div class="flex items-center gap-3 mb-6">
              <div class="w-8 h-8 bg-[#0983FD] rounded-md flex items-center justify-center">
                <Logo class="w-[22px] h-[22px] text-white" />
              </div>
              <span class="text-xl font-bold text-[#0983FD]">Bitcoin API</span>
            </div>
            <p class="text-sm text-[#565d6d] leading-relaxed mb-6">
              Making Bitcoin development accessible, secure, and scalable for everyone. Powering the next generation of
              fintech apps.
            </p>
          </div>

          <div>
            <h5 class="font-semibold text-[#171a1f] mb-6">Product</h5>
            <ul class="space-y-4 text-sm">
              <li><a href="/products" class="hover:text-[#0983FD]">Products</a></li>
              <li><a href="/docs" class="hover:text-[#0983FD]">Documentation</a></li>
              <li><a href="/pricing" class="hover:text-[#0983FD]">Pricing</a></li>
            </ul>
          </div>
          <div>
            <h5 class="font-semibold text-[#171a1f] mb-6">Company</h5>
            <ul class="space-y-4 text-sm">
              <li><a href="/about" class="hover:text-[#0983FD]">About</a></li>
              <li><a href="#" data-open-tawk class="hover:text-[#0983FD]">Contact</a></li>
            </ul>
          </div>
          <div>
            <h5 class="font-semibold text-[#171a1f] mb-6">Resources</h5>
            <ul class="space-y-4 text-sm">
              <li><a href="/help" class="hover:text-[#0983FD]">Help Center</a></li>
              <li><a href="/privacy-policy" class="hover:text-[#0983FD]">Privacy Policy</a></li>
              <li><a href="/terms" class="hover:text-[#0983FD]">Terms of Service</a></li>
            </ul>
          </div>
        </div>

        <div class="pt-4 border-t border-[#dee1e6] flex flex-col sm:flex-row justify-between items-center gap-2">
          <p class="text-xs text-[#565d6d]">© {new Date().getFullYear()} Bitcoin API. All rights reserved.</p>
        </div>
      </div>
    </footer>
  {tawk && (
    <script is:inline>
      var Tawk_API=Tawk_API||{}, Tawk_LoadStart=new Date();
      (function(){
        var s1=document.createElement("script"),s0=document.getElementsByTagName("script")[0];
        s1.async=true;
        s1.src='https://embed.tawk.to/69e0db914b03f31c3c2e7c6c/1jmb5jc8f';
        s1.charset='UTF-8';
        s1.setAttribute('crossorigin','*');
        s0.parentNode.insertBefore(s1,s0);
      })();
    </script>
  )}
  </body>
</html>

<script>
  import { userStore, fetchUser } from '@stores/auth';
  await fetchUser();

  const menuBtn = document.getElementById('mobile-menu-btn');
  const closeBtn = document.getElementById('mobile-menu-close');
  const sidebar = document.getElementById('mobile-sidebar');
  const overlay = document.getElementById('mobile-sidebar-overlay');

  function openSidebar() {
    overlay?.classList.remove('hidden');
    requestAnimationFrame(() => {
      overlay?.classList.remove('opacity-0');
      sidebar?.classList.remove('translate-x-full');
    });
    document.body.style.overflow = 'hidden';
  }

  function closeSidebar() {
    overlay?.classList.add('opacity-0');
    sidebar?.classList.add('translate-x-full');
    document.body.style.overflow = '';
    sidebar?.addEventListener('transitionend', () => {
      overlay?.classList.add('hidden');
    }, { once: true });
  }

  menuBtn?.addEventListener('click', openSidebar);
  closeBtn?.addEventListener('click', closeSidebar);
  overlay?.addEventListener('click', closeSidebar);

  document.querySelectorAll('[data-open-tawk]').forEach((el) => {
    el.addEventListener('click', (e) => {
      e.preventDefault();
      const tawk = (window as any).Tawk_API;
      if (tawk?.maximize) {
        tawk.maximize();
      }
    });
  });
</script>
