---
import '@styles/global.scss';
import { languages } from '@i18n/ui';
import { useTranslations, useTranslatedPath } from '@i18n/utils';
import { getLocaleByPath, getRelativeLocaleUrl } from 'astro:i18n';
import { type Locale } from '@i18n/types';

interface Props {
  title: string;
  description?: string;
}

const {
  title,
  description = 'Access comprehensive Bitcoin data with the most comfortable API. Pay only for what you use. No hidden fees.',
} = Astro.props;
const lang = Astro.currentLocale as Locale;
const t = useTranslations(lang);
const translatePath = useTranslatedPath(lang);
---

<!doctype html>
<html lang={lang}>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width" />
    <meta name="description" content={description} />
    <meta name="generator" content={Astro.generator} />
    <title>{title}</title>
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" href="/favicon.ico" />
  </head>
  <body>
    <header class="header">
      <div class="header__inner">
        <a href={getRelativeLocaleUrl(lang)} class="logo">
          <span class="logo__icon">B</span>
          <span class="logo__text">BitAPI</span>
        </a>

        <input type="checkbox" id="nav-toggle" class="nav-toggle" aria-label="Toggle menu" />
        <label for="nav-toggle" class="nav-toggle__btn" aria-hidden="true">
          <span class="nav-toggle__line"></span>
          <span class="nav-toggle__line"></span>
          <span class="nav-toggle__line"></span>
        </label>

        <div class="header__menu">
          <nav class="nav">
            <a href={getRelativeLocaleUrl(lang, '/features')} class="nav__link">{t('Features')}</a>
            <a href={getRelativeLocaleUrl(lang, '/pricing')} class="nav__link">{t('Pricing')}</a>
            <a href={getRelativeLocaleUrl(lang, '/endpoints')} class="nav__link">{t('Endpoints')}</a>
            <a href={getRelativeLocaleUrl(lang, '/docs')} class="nav__link">{t('Docs')}</a>
          </nav>
          <div class="header__actions">
            <span class="lang-switcher">
              {
                Object.entries(languages).map(([l, label]) => (
                  <a href={getRelativeLocaleUrl(l)} class={lang === l ? 'lang-switcher__active' : ''}>
                    {label}
                  </a>
                ))
              }
            </span>
            <a href={getRelativeLocaleUrl(lang, '/signin')} class="header__link">{t('Sign In')}</a>
            <a href={getRelativeLocaleUrl(lang, '/signup')} class="btn btn--primary">{t('Get Started')}</a>
          </div>
        </div>
      </div>
    </header>

    <slot />

    <footer class="footer">
      <div class="footer__inner">
        <div class="footer__grid">
          <div class="footer__col">
            <h4 class="footer__heading">{t('Product')}</h4>
            <ul class="footer__links">
              <li><a href={getRelativeLocaleUrl(lang, '/features')}>{t('Features')}</a></li>
              <li><a href={getRelativeLocaleUrl(lang, '/pricing')}>{t('Pricing')}</a></li>
              <li><a href={getRelativeLocaleUrl(lang, '/endpoints')}>{t('Endpoints')}</a></li>
            </ul>
          </div>
          <div class="footer__col">
            <h4 class="footer__heading">{t('Resources')}</h4>
            <ul class="footer__links">
              <li><a href={getRelativeLocaleUrl(lang, '/docs')}>{t('Documentation')}</a></li>
              <li><a href={getRelativeLocaleUrl(lang, '/docs/api')}>{t('API Reference')}</a></li>
              <li><a href={getRelativeLocaleUrl(lang, '/changelog')}>{t('Changelog')}</a></li>
            </ul>
          </div>
          <div class="footer__col">
            <h4 class="footer__heading">{t('Company')}</h4>
            <ul class="footer__links">
              <li><a href={getRelativeLocaleUrl(lang, '/about')}>{t('About')}</a></li>
              <li><a href={getRelativeLocaleUrl(lang, '/contact')}>{t('Contact')}</a></li>
            </ul>
          </div>
          <div class="footer__col">
            <h4 class="footer__heading">{t('Legal')}</h4>
            <ul class="footer__links">
              <li><a href={getRelativeLocaleUrl(lang, '/privacy')}>{t('Privacy')}</a></li>
              <li><a href={getRelativeLocaleUrl(lang, '/terms')}>{t('Terms')}</a></li>
            </ul>
          </div>
        </div>
        <div class="footer__bottom">
          <p class="footer__copyright">© {new Date().getFullYear()} BitAPI. {t('All rights reserved')}.</p>
        </div>
      </div>
    </footer>
  </body>
</html>

<style lang="scss">
  .lang-switcher {
    display: flex;
    gap: 0.5rem;
    font-size: 0.875rem;
  }

  .lang-switcher a {
    color: var(--color-text-muted);
    text-decoration: none;
  }

  .lang-switcher a:hover,
  .lang-switcher__active {
    color: var(--color-text);
    font-weight: 600;
  }

  .header {
    border-bottom: 1px solid #eee;
    padding: 1rem 0;
  }

  .header__inner {
    max-width: var(--container-max);
    margin: 0 auto;
    padding: 0 1.5rem;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
    position: relative;
  }

  .nav-toggle {
    position: absolute;
    width: 1px;
    height: 1px;
    padding: 0;
    margin: -1px;
    overflow: hidden;
    clip: rect(0, 0, 0, 0);
    border: 0;
  }

  .nav-toggle__btn {
    display: none;
    flex-direction: column;
    justify-content: center;
    gap: 5px;
    width: 2.5rem;
    height: 2.5rem;
    padding: 0.5rem;
    cursor: pointer;
    border-radius: 0.375rem;
    transition: background-color 0.2s;
  }

  .nav-toggle__btn:hover {
    background: #f0f0f0;
  }

  .nav-toggle__line {
    display: block;
    width: 100%;
    height: 2px;
    background: var(--color-text);
    border-radius: 1px;
    transition:
      transform 0.2s,
      opacity 0.2s;
  }

  .header__menu {
    display: flex;
    align-items: center;
    gap: 1.5rem;
  }

  @media (max-width: 768px) {
    .header {
      position: relative;
    }

    .header__inner {
      flex-wrap: wrap;
    }

    .nav-toggle__btn {
      display: flex;
      order: 3;
      margin-left: auto;
    }

    .header__menu {
      order: 4;
      flex-basis: 100%;
      position: static;
      flex-direction: column;
      align-items: stretch;
      background: var(--color-bg);
      border-top: 1px solid #eee;
      padding: 1rem 1.5rem;
      gap: 0;
      max-height: 0;
      overflow: hidden;
      opacity: 0;
      transition:
        max-height 0.3s ease,
        opacity 0.2s;
      margin: 1rem -1.5rem 0;
    }

    .nav-toggle:checked ~ .header__menu {
      max-height: 20rem;
      opacity: 1;
    }

    .nav-toggle:checked ~ .nav-toggle__btn .nav-toggle__line:nth-child(1) {
      transform: translateY(7px) rotate(45deg);
    }

    .nav-toggle:checked ~ .nav-toggle__btn .nav-toggle__line:nth-child(2) {
      opacity: 0;
    }

    .nav-toggle:checked ~ .nav-toggle__btn .nav-toggle__line:nth-child(3) {
      transform: translateY(-7px) rotate(-45deg);
    }

    .nav {
      flex-direction: column;
      align-items: stretch;
      padding: 1rem 0;
      border-bottom: 1px solid #eee;
      margin-bottom: 1rem;
    }

    .nav__link {
      padding: 0.75rem 0;
      font-size: 1rem;
      text-align: center;
    }

    .header__actions {
      flex-direction: column;
      align-items: stretch;
      gap: 0.5rem;
    }

    .header__actions .btn {
      justify-content: center;
    }
  }

  .logo {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    text-decoration: none;
    color: var(--color-text);
    font-weight: 700;
    font-size: 1.25rem;
  }

  .logo__icon {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 2rem;
    height: 2rem;
    background: var(--color-accent);
    color: white;
    border-radius: 0.375rem;
  }

  .nav {
    display: flex;
    gap: 1.5rem;
  }

  .nav__link {
    color: var(--color-text-muted);
    text-decoration: none;
    font-size: 0.9375rem;
  }

  .nav__link:hover {
    color: var(--color-text);
  }

  .header__actions {
    display: flex;
    align-items: center;
    gap: 1rem;
  }

  .header__link {
    color: var(--color-text-muted);
    text-decoration: none;
  }

  .header__link:hover {
    color: var(--color-text);
  }

  :global(.btn) {
    display: inline-flex;
    align-items: center;
    padding: 0.5rem 1.25rem;
    font-size: 0.9375rem;
    font-weight: 600;
    text-decoration: none;
    border-radius: 0.375rem;
    transition: background-color 0.2s;
  }

  :global(.btn--primary) {
    background: var(--color-accent);
    color: white;
  }

  :global(.btn--primary:hover) {
    background: var(--color-accent-hover);
  }

  :global(.btn--secondary) {
    background: transparent;
    color: var(--color-text);
    border: 2px solid #333;
  }

  :global(.btn--secondary:hover) {
    background: rgba(0, 0, 0, 0.05);
  }

  .footer {
    margin-top: auto;
    border-top: 1px solid #eee;
    padding: 3rem 0 2rem;
  }

  .footer__inner {
    max-width: var(--container-max);
    margin: 0 auto;
    padding: 0 1.5rem;
  }

  .footer__grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(140px, 1fr));
    gap: 2rem;
    margin-bottom: 2rem;
  }

  .footer__heading {
    font-size: 0.875rem;
    font-weight: 600;
    margin: 0 0 0.75rem;
    color: var(--color-text);
  }

  .footer__links {
    margin: 0;
    padding: 0;
    list-style: none;
  }

  .footer__links li {
    margin-bottom: 0.5rem;
  }

  .footer__links a {
    font-size: 0.875rem;
    color: var(--color-text-muted);
    text-decoration: none;
  }

  .footer__links a:hover {
    color: var(--color-text);
  }

  .footer__bottom {
    padding-top: 2rem;
    border-top: 1px solid #eee;
  }

  .footer__copyright {
    margin: 0;
    font-size: 0.875rem;
    color: var(--color-text-muted);
  }

  @media (max-width: 768px) {
    .footer {
      padding: 2rem 0 1.5rem;
    }

    .footer__grid {
      grid-template-columns: repeat(2, 1fr);
      gap: 1.5rem;
    }

    .footer__bottom {
      padding-top: 1.5rem;
    }
  }
</style>
