---
import DocsLayout from '@layouts/DocsLayout.astro';

const errorResponseCode = `{
  "code": "ERROR_CODE",
  "message": "Human-readable error description"
}`;
---

<DocsLayout>
  <nav class="breadcrumbs" aria-label="Breadcrumb">
    <a href="/docs">Docs</a>
    <span class="breadcrumbs__sep">›</span>
    <span>Introduction</span>
  </nav>

  <h1 class="docs-page-title">Introduction</h1>
  <p class="docs-page-lead">
    Bitcoin API gives you fast, reliable access to Bitcoin market data through a simple REST API and real-time WebSocket
    streams. Built for developers and vibe coders who want to ship quickly without running their own infrastructure.
  </p>

  <h2 id="what-you-can-do">What you can do</h2>
  <div class="feature-grid">
    <div class="feature-card">
      <div class="feature-card__icon">
        <svg
          width="20"
          height="20"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="2"
          stroke-linecap="round"
          stroke-linejoin="round"
          ><line x1="12" y1="1" x2="12" y2="23"></line><path d="M17 5H9.5a3.5 3.5 0 0 0 0 7h5a3.5 3.5 0 0 1 0 7H6"
          ></path></svg
        >
      </div>
      <h3>Real-time Prices</h3>
      <p>Get live cryptocurrency prices from major exchanges via REST or WebSocket.</p>
    </div>
    <div class="feature-card">
      <div class="feature-card__icon">
        <svg
          width="20"
          height="20"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="2"
          stroke-linecap="round"
          stroke-linejoin="round"><polyline points="22 12 18 12 15 21 9 3 6 12 2 12"></polyline></svg
        >
      </div>
      <h3>WebSocket Streams</h3>
      <p>Subscribe to live data feeds and receive price updates the moment they happen.</p>
    </div>
    <div class="feature-card">
      <div class="feature-card__icon">
        <svg
          width="20"
          height="20"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="2"
          stroke-linecap="round"
          stroke-linejoin="round"
          ><rect x="3" y="11" width="18" height="11" rx="2" ry="2"></rect><path d="M7 11V7a5 5 0 0 1 10 0v4"
          ></path></svg
        >
      </div>
      <h3>Secure & Authenticated</h3>
      <p>All endpoints are protected with Bearer token authentication over HTTPS.</p>
    </div>
  </div>

  <h2 id="base-url">Base URL</h2>
  <p class="docs-page-text">All API requests are made to the following base URL:</p>
  <div class="base-url-block">
    <code>https://api.bitcoinapi.dev</code>
  </div>

  <h2 id="available-endpoints">Available Endpoints</h2>
  <div class="endpoint-list">
    <div class="endpoint-list__item">
      <span class="endpoint-list__method">GET</span>
      <a href="/docs/price/current" class="endpoint-list__path">/v1/prices/current</a>
      <span class="endpoint-list__desc">Get the current price of a trading pair</span>
    </div>
  </div>
  <p class="docs-page-text" style="margin-top: 1rem; font-size: 0.8125rem;">
    More endpoints are being added regularly. Check back for updates on blockchain data, transactions, and more.
  </p>

  <h2 id="response-format">Response Format</h2>
  <p class="docs-page-text">
    All responses are returned as JSON. Successful responses return the data directly. Error responses follow a
    consistent shape:
  </p>
  <div class="code-block-wrap">
    <pre class="code-block-dark"><code set:text={errorResponseCode} /></pre>
  </div>

  <h2 id="next-steps">Next Steps</h2>
  <ul class="next-steps-list">
    <li><a href="/docs/quickstart">Quickstart Guide</a> — Make your first API call in under 2 minutes</li>
    <li><a href="/docs/authentication">Authentication</a> — Learn how to authenticate your requests</li>
    <li><a href="/docs/price/current">Current Price</a> — Explore the price endpoint reference</li>
  </ul>
</DocsLayout>

<style>
  .breadcrumbs {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    font-size: 0.8125rem;
    color: var(--color-text-muted);
    margin-bottom: 1.5rem;
  }

  .breadcrumbs a {
    color: var(--color-text-muted);
    text-decoration: none;
  }

  .breadcrumbs a:hover {
    color: var(--color-accent);
  }

  .breadcrumbs__sep {
    opacity: 0.4;
  }

  .docs-page-title {
    font-size: 2rem;
    font-weight: 800;
    margin: 0 0 0.75rem;
    color: var(--color-text);
  }

  .docs-page-lead {
    font-size: 1.0625rem;
    color: var(--color-text-muted);
    line-height: 1.7;
    margin: 0 0 2.5rem;
    max-width: 640px;
  }

  .docs-page-text {
    font-size: 0.9375rem;
    color: var(--color-text-muted);
    line-height: 1.7;
    margin: 0 0 1rem;
    max-width: 640px;
  }

  h2 {
    font-size: 1.375rem;
    margin: 2.5rem 0 1rem;
  }

  /* ── Feature grid ── */

  .feature-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(200px, 1fr));
    gap: 1rem;
    margin-bottom: 1rem;
  }

  .feature-card {
    border: 1px solid #e2e8f0;
    border-radius: 10px;
    padding: 1.25rem;
  }

  .feature-card__icon {
    width: 40px;
    height: 40px;
    background: #eff6ff;
    border-radius: 8px;
    display: flex;
    align-items: center;
    justify-content: center;
    color: var(--color-accent);
    margin-bottom: 0.75rem;
  }

  .feature-card h3 {
    font-size: 0.9375rem;
    font-weight: 600;
    margin: 0 0 0.375rem;
  }

  .feature-card p {
    font-size: 0.8125rem;
    color: var(--color-text-muted);
    line-height: 1.5;
    margin: 0;
  }

  /* ── Base URL block ── */

  .base-url-block {
    background: #1e293b;
    border-radius: 8px;
    padding: 1rem 1.25rem;
    margin-bottom: 1rem;
  }

  .base-url-block code {
    color: #e2e8f0;
    font-size: 0.9375rem;
  }

  /* ── Endpoint list ── */

  .endpoint-list {
    border: 1px solid #e2e8f0;
    border-radius: 8px;
    overflow: hidden;
  }

  .endpoint-list__item {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    padding: 0.875rem 1rem;
    font-size: 0.875rem;
  }

  .endpoint-list__item:not(:last-child) {
    border-bottom: 1px solid #f1f5f9;
  }

  .endpoint-list__method {
    display: inline-flex;
    align-items: center;
    padding: 0.2rem 0.5rem;
    background: #dbeafe;
    color: #1d4ed8;
    font-size: 0.6875rem;
    font-weight: 700;
    border-radius: 4px;
    letter-spacing: 0.03em;
    flex-shrink: 0;
  }

  .endpoint-list__path {
    font-family: ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, monospace;
    color: var(--color-text);
    text-decoration: none;
    font-weight: 500;
    font-size: 0.8125rem;
  }

  .endpoint-list__path:hover {
    color: var(--color-accent);
  }

  .endpoint-list__desc {
    color: var(--color-text-muted);
    margin-left: auto;
  }

  /* ── Code block ── */

  .code-block-wrap {
    margin-bottom: 1.5rem;
  }

  .code-block-dark {
    background: #1e293b;
    border-radius: 8px;
    padding: 1.25rem;
    overflow-x: auto;
    margin: 0;
  }

  .code-block-dark code {
    color: #e2e8f0;
    font-size: 0.8125rem;
    line-height: 1.7;
  }

  /* ── Next steps ── */

  .next-steps-list {
    list-style: none;
    padding: 0;
    margin: 0 0 2rem;
  }

  .next-steps-list li {
    padding: 0.5rem 0;
    font-size: 0.9375rem;
    color: var(--color-text-muted);
    line-height: 1.6;
  }

  .next-steps-list li::before {
    content: '→ ';
    color: var(--color-accent);
    font-weight: 600;
  }

  .next-steps-list a {
    color: var(--color-accent);
    text-decoration: none;
    font-weight: 500;
  }

  .next-steps-list a:hover {
    text-decoration: underline;
  }

  @media (max-width: 640px) {
    .endpoint-list__desc {
      display: none;
    }
  }
</style>
