---
import DocsLayout from '@layouts/DocsLayout.astro';

const responseExample = `{
  "price": "67482.35",
  "time": "2025-04-12T14:32:05.000Z"
}`;
---

<DocsLayout>
  <nav class="breadcrumbs" aria-label="Breadcrumb">
    <a href="/docs">Docs</a>
    <span class="breadcrumbs__sep">›</span>
    <a href="/docs">API Reference</a>
    <span class="breadcrumbs__sep">›</span>
    <span>Current Price</span>
  </nav>

  <h1 class="endpoint-title">Current Price</h1>
  <p class="endpoint-desc">
    Retrieves the current price of a cryptocurrency pair in real-time. You can also subscribe to live price updates via
    WebSocket on the same endpoint.
  </p>

  <div class="endpoint-url">
    <span class="endpoint-url__method">GET</span>
    <code class="endpoint-url__path">/v1/prices/current</code>
    <button class="endpoint-url__copy" data-copy="/v1/prices/current" aria-label="Copy endpoint URL">
      <svg
        width="16"
        height="16"
        viewBox="0 0 24 24"
        fill="none"
        stroke="currentColor"
        stroke-width="2"
        stroke-linecap="round"
        stroke-linejoin="round"
        ><rect x="9" y="9" width="13" height="13" rx="2"></rect><path
          d="M5 15H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h9a2 2 0 0 1 2 2v1"></path></svg
      >
    </button>
  </div>

  <div class="rate-limit">
    <svg
      class="rate-limit__icon"
      width="16"
      height="16"
      viewBox="0 0 24 24"
      fill="none"
      stroke="currentColor"
      stroke-width="2"
      stroke-linecap="round"
      stroke-linejoin="round"
      ><circle cx="12" cy="12" r="10"></circle><polyline points="12 6 12 12 16 14"></polyline></svg
    >
    <div class="rate-limit__info">
      <span class="rate-limit__label">Rate limit</span>
      <span class="rate-limit__value">100 req / min</span>
    </div>
    <span class="rate-limit__note">Monthly billing per endpoint. Increase to raise throughput.</span>
  </div>

  <h2 id="query-parameters">Query Parameters</h2>

  <div class="params-table-wrap">
    <table class="params-table">
      <thead>
        <tr>
          <th>Parameter</th>
          <th>Type</th>
          <th>Description</th>
        </tr>
      </thead>
      <tbody>
        <tr>
          <td><a href="#query-parameters" class="param-name">symbol</a></td>
          <td><code>string</code></td>
          <td>The trading pair symbol. Currently supported: <code>btcusdt</code>.</td>
        </tr>
      </tbody>
    </table>
  </div>

  <h2 id="request-example">Request Example</h2>

  <div class="code-example">
    <div class="code-example__header">
      <span class="code-example__lang">CURL</span>
      <button class="code-example__copy" data-copy-block="request-code" aria-label="Copy request example">
        <svg
          width="14"
          height="14"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="2"
          stroke-linecap="round"
          stroke-linejoin="round"
          ><rect x="9" y="9" width="13" height="13" rx="2"></rect><path
            d="M5 15H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h9a2 2 0 0 1 2 2v1"></path></svg
        >
      </button>
    </div>
    <pre
      class="code-example__body"
      id="request-code"><code>curl --request GET \
  --url https://api.bitcoinapi.dev/v1/prices/current?symbol=btcusdt \
  --header 'Authorization: Bearer YOUR_API_KEY' \
  --header 'Accept: application/json'</code></pre>
  </div>

  <h2 id="response-example">Response Example</h2>

  <div class="code-example code-example--response">
    <div class="code-example__header">
      <div class="code-example__tabs">
        <span class="code-example__lang code-example__lang--active">JSON</span>
      </div>
      <span class="code-example__status">200 OK</span>
    </div>
    <pre class="code-example__body" id="response-code"><code set:text={responseExample} /></pre>
  </div>

  <h2 id="response-schema">Response Schema</h2>

  <div class="params-table-wrap">
    <table class="params-table">
      <thead>
        <tr>
          <th>Field</th>
          <th>Type</th>
          <th>Description</th>
        </tr>
      </thead>
      <tbody>
        <tr>
          <td><code>price</code></td>
          <td><code>string</code></td>
          <td>The current price as a decimal string.</td>
        </tr>
        <tr>
          <td><code>time</code></td>
          <td><code>string</code></td>
          <td>ISO 8601 timestamp of the price update.</td>
        </tr>
      </tbody>
    </table>
  </div>

  <h2 id="websocket">WebSocket</h2>

  <p class="endpoint-desc">
    You can subscribe to real-time price updates by connecting via WebSocket to the same endpoint. The server will push
    new price data as it becomes available.
  </p>

  <div class="code-example">
    <div class="code-example__header">
      <span class="code-example__lang">Terminal</span>
      <button class="code-example__copy" data-copy-block="ws-code" aria-label="Copy WebSocket example">
        <svg
          width="14"
          height="14"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="2"
          stroke-linecap="round"
          stroke-linejoin="round"
          ><rect x="9" y="9" width="13" height="13" rx="2"></rect><path
            d="M5 15H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h9a2 2 0 0 1 2 2v1"></path></svg
        >
      </button>
    </div>
    <pre
      class="code-example__body"
      id="ws-code"><code>wscat -c wss://api.bitcoinapi.dev/v1/prices/current?symbol=btcusdt</code></pre>
  </div>
</DocsLayout>

<style>
  .breadcrumbs {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    font-size: 0.8125rem;
    color: var(--color-text-muted);
    margin-bottom: 1.5rem;
  }

  .breadcrumbs a {
    color: var(--color-text-muted);
    text-decoration: none;
  }

  .breadcrumbs a:hover {
    color: var(--color-accent);
  }

  .breadcrumbs__sep {
    opacity: 0.4;
  }

  .endpoint-title {
    font-size: 2rem;
    font-weight: 800;
    margin: 0 0 0.75rem;
    color: var(--color-text);
  }

  .endpoint-desc {
    font-size: 0.9375rem;
    color: var(--color-text-muted);
    line-height: 1.7;
    margin: 0 0 1.5rem;
    max-width: 640px;
  }

  .endpoint-url {
    display: inline-flex;
    align-items: center;
    gap: 0.75rem;
    background: #f1f5f9;
    border: 1px solid #e2e8f0;
    border-radius: 8px;
    padding: 0.625rem 1rem;
    margin-bottom: 1rem;
  }

  .endpoint-url__method {
    display: inline-flex;
    align-items: center;
    padding: 0.25rem 0.625rem;
    background: #dbeafe;
    color: #1d4ed8;
    font-size: 0.75rem;
    font-weight: 700;
    border-radius: 4px;
    letter-spacing: 0.03em;
  }

  .endpoint-url__path {
    font-size: 0.875rem;
    font-weight: 500;
    color: var(--color-text);
  }

  .endpoint-url__copy {
    background: none;
    border: none;
    cursor: pointer;
    color: var(--color-text-muted);
    padding: 0.25rem;
    border-radius: 4px;
    display: flex;
    align-items: center;
  }

  .endpoint-url__copy:hover {
    color: var(--color-accent);
    background: rgba(9, 131, 253, 0.08);
  }

  .rate-limit {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    background: #fefce8;
    border: 1px solid #fde68a;
    border-radius: 8px;
    padding: 0.75rem 1rem;
    margin-bottom: 2rem;
    font-size: 0.8125rem;
  }

  .rate-limit__icon {
    color: #ca8a04;
    flex-shrink: 0;
  }

  .rate-limit__info {
    display: flex;
    align-items: center;
    gap: 0.5rem;
  }

  .rate-limit__label {
    font-weight: 500;
    color: var(--color-text);
  }

  .rate-limit__value {
    font-weight: 700;
    color: var(--color-text);
  }

  .rate-limit__note {
    color: var(--color-text-muted);
    margin-left: auto;
  }

  /* ── Tables ── */

  .params-table-wrap {
    overflow-x: auto;
    margin-bottom: 2rem;
  }

  .params-table {
    width: 100%;
    border-collapse: collapse;
    font-size: 0.875rem;
  }

  .params-table th {
    text-align: left;
    padding: 0.75rem 1rem;
    background: #f8fafc;
    border-bottom: 2px solid #e2e8f0;
    font-weight: 600;
    color: var(--color-text);
  }

  .params-table td {
    padding: 0.75rem 1rem;
    border-bottom: 1px solid #f1f5f9;
    color: var(--color-text-muted);
    vertical-align: top;
  }

  .params-table code {
    background: #f1f5f9;
    padding: 0.125rem 0.375rem;
    border-radius: 4px;
    font-size: 0.8125rem;
    color: var(--color-text);
  }

  .param-name {
    color: var(--color-accent);
    text-decoration: none;
    font-weight: 500;
  }

  .param-name:hover {
    text-decoration: underline;
  }

  /* ── Code blocks ── */

  .code-example {
    border-radius: 10px;
    overflow: hidden;
    border: 1px solid #e2e8f0;
    margin-bottom: 2rem;
  }

  .code-example__header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    background: #f8fafc;
    padding: 0.5rem 1rem;
    border-bottom: 1px solid #e2e8f0;
  }

  .code-example__tabs {
    display: flex;
    gap: 0.75rem;
  }

  .code-example__lang {
    font-size: 0.75rem;
    font-weight: 600;
    color: var(--color-text);
    text-transform: uppercase;
    letter-spacing: 0.03em;
  }

  .code-example__lang--active {
    color: var(--color-accent);
  }

  .code-example__status {
    display: inline-flex;
    align-items: center;
    padding: 0.2rem 0.625rem;
    background: #dcfce7;
    color: #16a34a;
    font-size: 0.75rem;
    font-weight: 600;
    border-radius: 4px;
  }

  .code-example__copy {
    background: none;
    border: none;
    cursor: pointer;
    color: var(--color-text-muted);
    padding: 0.25rem;
    border-radius: 4px;
    display: flex;
    align-items: center;
  }

  .code-example__copy:hover {
    color: var(--color-accent);
  }

  .code-example__body {
    margin: 0;
    padding: 1.25rem;
    background: #1e293b;
    overflow-x: auto;
  }

  .code-example__body code {
    font-size: 0.8125rem;
    line-height: 1.7;
    color: #e2e8f0;
  }

  /* ── Responsive ── */

  @media (max-width: 640px) {
    .rate-limit {
      flex-wrap: wrap;
    }

    .rate-limit__note {
      margin-left: 0;
      width: 100%;
    }

    .endpoint-url {
      width: 100%;
    }
  }
</style>

<script>
  document.querySelectorAll<HTMLButtonElement>('[data-copy]').forEach((btn) => {
    btn.addEventListener('click', () => {
      const text = btn.dataset.copy!;
      navigator.clipboard.writeText(text);
    });
  });

  document.querySelectorAll<HTMLButtonElement>('[data-copy-block]').forEach((btn) => {
    btn.addEventListener('click', () => {
      const blockId = btn.dataset.copyBlock!;
      const block = document.getElementById(blockId);
      if (block) {
        navigator.clipboard.writeText(block.textContent!.trim());
      }
    });
  });
</script>
