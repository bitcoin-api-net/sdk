---
import DocsLayout from '@layouts/DocsLayout.astro';
const publicApiUrl = import.meta.env.PUBLIC_API_URL || 'http://localhost:3000/api';
const openApiUrl = `${publicApiUrl}/openapi.json`;
---

<DocsLayout>
  <nav class="breadcrumbs" aria-label="Breadcrumb">
    <a href="/docs">Docs</a>
    <span class="breadcrumbs__sep">›</span>
    <span>Integrations</span>
    <span class="breadcrumbs__sep">›</span>
    <span>OpenAPI</span>
  </nav>

  <h1 class="docs-page-title">OpenAPI specification</h1>
  <p class="docs-page-lead">
    Our entire API is defined using the OpenAPI 3.x specification. This standard format allows you to import the API
    surface into your developer tools, generate client SDKs, or enable AI agents to understand our endpoints.
  </p>

  <h2 id="connect">Connect</h2>
  <p class="docs-page-text">Use the direct link to the specification or download the JSON file to your machine.</p>

  <div class="cta-group">
    <a
      href={`${openApiUrl}?download=true`}
      download="openapi.json"
      target="_blank"
      class="docs-cta-btn docs-cta-btn--primary">
      <svg
        width="18"
        height="18"
        viewBox="0 0 24 24"
        fill="none"
        stroke="currentColor"
        stroke-width="2"
        stroke-linecap="round"
        stroke-linejoin="round"
        ><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"></path><polyline points="7 10 12 15 17 10"></polyline><line
          x1="12"
          y1="15"
          x2="12"
          y2="3"></line></svg
      >
      Download OpenAPI
    </a>
    <button id="copy-openapi-url" class="docs-cta-btn docs-cta-btn--outline" data-url={openApiUrl}>
      <svg
        width="18"
        height="18"
        viewBox="0 0 24 24"
        fill="none"
        stroke="currentColor"
        stroke-width="2"
        stroke-linecap="round"
        stroke-linejoin="round"
        ><rect x="9" y="9" width="13" height="13" rx="2" ry="2"></rect><path
          d="M5 15H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h9a2 2 0 0 1 2 2v1"></path></svg
      >
      <span>Copy URL</span>
    </button>
  </div>

  <h2 id="what-you-get">What you get</h2>
  <div class="feature-grid">
    <div class="feature-card">
      <div class="feature-card__icon">
        <svg
          width="20"
          height="20"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="2"
          stroke-linecap="round"
          stroke-linejoin="round"
          ><polyline points="16 18 22 12 16 6"></polyline><polyline points="8 6 2 12 8 18"></polyline></svg
        >
      </div>
      <h3>Type Safety</h3>
      <p>
        Import the schema into your TypeScript project to get full autocompletion and type checking for all requests and
        responses.
      </p>
    </div>
    <div class="feature-card">
      <div class="feature-card__icon">
        <svg
          width="20"
          height="20"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="2"
          stroke-linecap="round"
          stroke-linejoin="round"
          ><path d="M12 2v4"></path><path d="m16.2 4.2 2.8 2.8"></path><path d="M18 12h4"></path><path
            d="m16.2 19.8 2.8-2.8"></path><path d="M12 18v4"></path><path d="m4.2 19.8 2.8-2.8"></path><path d="M2 12h4"
          ></path><path d="m4.2 4.2 2.8 2.8"></path></svg
        >
      </div>
      <h3>Auto-generated SDKs</h3>
      <p>
        Use tools like OpenAPI Generator or Fern to create high-quality client libraries in any programming language.
      </p>
    </div>
    <div class="feature-card">
      <div class="feature-card__icon">
        <svg
          width="20"
          height="20"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="2"
          stroke-linecap="round"
          stroke-linejoin="round"
          ><rect x="3" y="3" width="18" height="18" rx="2"></rect><circle cx="8.5" cy="10" r="1.5"></circle><circle
            cx="15.5"
            cy="10"
            r="1.5"></circle><path d="M8 15h8"></path></svg
        >
      </div>
      <h3>AI Agent Integration</h3>
      <p>Connect Bitcoin API to ChatGPT Actions, Cursor, or Windsurf by providing the OpenAPI URL.</p>
    </div>
  </div>

  <h2 id="how-to-use">How to use</h2>
  <div class="instruction-list">
    <div class="instruction-item">
      <h3>Postman</h3>
      <p>
        Go to <code>Import</code> → <code>Link</code> → paste the OpenAPI URL. Postman will automatically generate a collection
        with all endpoints and documentation.
      </p>
    </div>
    <div class="instruction-item">
      <h3>Insomnia / Bruno</h3>
      <p>
        Select <code>Create</code> → <code>Import from URL</code> and provide the link. You'll get a pre-configured workspace
        ready for testing.
      </p>
    </div>
  </div>
</DocsLayout>

<script>
  const copyBtn = document.getElementById('copy-openapi-url');
  if (copyBtn) {
    copyBtn.addEventListener('click', async () => {
      const url = copyBtn.getAttribute('data-url');
      if (!url) return;

      try {
        await navigator.clipboard.writeText(url);
        const span = copyBtn.querySelector('span');
        if (span) {
          const originalText = span.textContent;
          span.textContent = 'Copied!';
          setTimeout(() => {
            span.textContent = originalText;
          }, 2000);
        }
      } catch (err) {
        console.error('Failed to copy: ', err);
      }
    });
  }
</script>

<style>
  .breadcrumbs {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    font-size: 0.8125rem;
    color: var(--color-text-muted);
    margin-bottom: 1.5rem;
  }

  .breadcrumbs a {
    color: var(--color-text-muted);
    text-decoration: none;
  }

  .breadcrumbs a:hover {
    color: var(--color-accent);
  }

  .breadcrumbs__sep {
    opacity: 0.4;
  }

  .docs-page-title {
    font-size: 2rem;
    font-weight: 800;
    margin: 0 0 0.75rem;
    color: var(--color-text);
  }

  .docs-page-lead {
    font-size: 1.0625rem;
    color: var(--color-text-muted);
    line-height: 1.7;
    margin: 0 0 2.5rem;
    max-width: 640px;
  }

  .docs-page-text {
    font-size: 0.9375rem;
    color: var(--color-text-muted);
    line-height: 1.7;
    margin: 0 0 1rem;
    max-width: 640px;
  }

  h2 {
    font-size: 1.375rem;
    margin: 2.5rem 0 1rem;
  }

  .cta-group {
    display: flex;
    flex-wrap: wrap;
    gap: 0.75rem;
    margin-bottom: 2.5rem;
  }

  .feature-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(250px, 1fr));
    gap: 1rem;
    margin-bottom: 2rem;
  }

  .feature-card {
    border: 1px solid #e2e8f0;
    border-radius: 10px;
    padding: 1.25rem;
  }

  .feature-card__icon {
    width: 40px;
    height: 40px;
    background: #eff6ff;
    border-radius: 8px;
    display: flex;
    align-items: center;
    justify-content: center;
    color: var(--color-accent);
    margin-bottom: 0.75rem;
  }

  .feature-card h3 {
    font-size: 0.9375rem;
    font-weight: 600;
    margin: 0 0 0.375rem;
  }

  .feature-card p {
    font-size: 0.8125rem;
    color: var(--color-text-muted);
    line-height: 1.5;
    margin: 0;
  }

  .instruction-list {
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
    margin-bottom: 3rem;
  }

  .instruction-item {
    border-left: 2px solid #e2e8f0;
    padding-left: 1.25rem;
  }

  .instruction-item h3 {
    font-size: 1rem;
    font-weight: 600;
    margin: 0 0 0.5rem;
  }

  .instruction-item p {
    font-size: 0.875rem;
    color: var(--color-text-muted);
    line-height: 1.6;
    margin: 0;
  }

  code {
    background: #f1f5f9;
    padding: 0.125rem 0.25rem;
    border-radius: 4px;
    font-size: 0.875rem;
  }
</style>
