---
import DocsLayout from '@layouts/DocsLayout.astro';

const firstRequestExample = `const response = await fetch(
  'https://api.bitcoinapi.dev/v1/prices/current?symbol=btcusdt',
  { headers: { Authorization: 'Bearer YOUR_API_KEY' } }
);
const data = await response.json();
console.log(data);`;

const websocketExample = `const ws = new WebSocket(
  'wss://api.bitcoinapi.dev/v1/prices/current?symbol=btcusdt&apiKey=YOUR_API_KEY'
);

ws.onmessage = (event) => {
  const data = JSON.parse(event.data);
  console.log(data);
};`;

const responseExample = `{
  "price": "67482.35",
  "time": "2025-04-12T14:32:05.000Z"
}`;
---

<DocsLayout>
  <nav class="breadcrumbs" aria-label="Breadcrumb">
    <a href="/docs">Docs</a>
    <span class="breadcrumbs__sep">›</span>
    <span>Quickstart Guide</span>
  </nav>

  <h1 class="docs-page-title">Quickstart Guide</h1>
  <p class="docs-page-lead">
    Get up and running with Bitcoin API in 2 minutes.
  </p>

  <h2 id="step-1-create-account">Step 1: Create an Account</h2>
  <p class="docs-page-text">
    <a href="/authorization/sign-up" class="docs-link">Sign up</a> for free. You can register with your email or use Google sign-in.
  </p>

  <h2 id="step-2-get-api-key">Step 2: Get Your API Key</h2>
  <p class="docs-page-text">
    Go to your <a href="/profile/home" class="docs-link">profile</a> and grab the default API key.
  </p>
  <div class="callout">
    <svg
      class="callout__icon"
      width="16"
      height="16"
      viewBox="0 0 24 24"
      fill="none"
      stroke="currentColor"
      stroke-width="2"
      stroke-linecap="round"
      stroke-linejoin="round"
      ><circle cx="12" cy="12" r="10"></circle><line x1="12" y1="8" x2="12" y2="12"></line><line
        x1="12"
        y1="16"
        x2="12.01"
        y2="16"></line></svg
    >
    <p>Keep your API key secret. Do not commit it to version control or expose it in client-side code.</p>
  </div>

  <h2 id="step-3-first-request">Step 3: Make Your First Request</h2>
  <p class="docs-page-text">Let's fetch the current Bitcoin price. Run this in your browser console or any JavaScript runtime:</p>

  <div class="code-block-wrap">
    <div class="code-block-header">
      <span class="code-block-lang">JavaScript</span>
      <div class="code-block-actions">
        <a
          href="https://hopp.sh/r/j6Fo2zFIqfFW"
          target="_blank"
          rel="noopener noreferrer"
          class="code-block-run">
          <svg
            width="12"
            height="12"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2.5"
            stroke-linecap="round"
            stroke-linejoin="round"
            ><polygon points="5 3 19 12 5 21 5 3"></polygon></svg
          >
          Run in test environment
        </a>
        <button class="code-block-copy" data-copy-block="first-request" aria-label="Copy code">
          <svg
            width="14"
            height="14"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2"
            stroke-linecap="round"
            stroke-linejoin="round"
            ><rect x="9" y="9" width="13" height="13" rx="2"></rect><path
              d="M5 15H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h9a2 2 0 0 1 2 2v1"></path></svg
          >
        </button>
      </div>
    </div>
    <pre class="code-block-dark" id="first-request"><code set:text={firstRequestExample} /></pre>
  </div>

  <p class="docs-page-text">You should see a response like this:</p>

  <div class="code-block-wrap">
    <div class="code-block-header">
      <span class="code-block-lang">JSON</span>
      <span class="code-block-status">200 OK</span>
    </div>
    <pre class="code-block-dark"><code set:text={responseExample} /></pre>
  </div>

  <h3 id="or-connect-to-websocket" class="docs-page-subtitle">Or connect to WebSocket</h3>
  <p class="docs-page-text">
    Want real-time price updates? Open a WebSocket connection. Run this in your browser console or any JavaScript runtime:
  </p>

  <div class="code-block-wrap">
    <div class="code-block-header">
      <span class="code-block-lang">JavaScript</span>
      <div class="code-block-actions">
        <a
          href="https://www.postman.com/interstellar-meadow-418331/bitcoin-api/ws-raw-request/69ecddb7abcd83e5d5cfbed9/bitcoin-api?action=share&creator=12471752"
          target="_blank"
          rel="noopener noreferrer"
          class="code-block-run">
          <svg
            width="12"
            height="12"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2.5"
            stroke-linecap="round"
            stroke-linejoin="round"
            ><polygon points="5 3 19 12 5 21 5 3"></polygon></svg
          >
          Run in test environment
        </a>
        <button class="code-block-copy" data-copy-block="websocket-example" aria-label="Copy code">
          <svg
            width="14"
            height="14"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2"
            stroke-linecap="round"
            stroke-linejoin="round"
            ><rect x="9" y="9" width="13" height="13" rx="2"></rect><path
              d="M5 15H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h9a2 2 0 0 1 2 2v1"></path></svg
          >
        </button>
      </div>
    </div>
    <pre class="code-block-dark" id="websocket-example"><code set:text={websocketExample} /></pre>
  </div>
  <p class="docs-page-text">You'll receive JSON messages with updated prices as they come in from the exchange.</p>

  <h2 id="next-steps">Next Steps</h2>
  <ul class="next-steps-list">
    <li><a href="/docs/price/current">Current Price API</a> — Full endpoint reference with all parameters</li>
  </ul>
</DocsLayout>

<style>
  .breadcrumbs {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    font-size: 0.8125rem;
    color: var(--color-text-muted);
    margin-bottom: 1.5rem;
  }

  .breadcrumbs a {
    color: var(--color-text-muted);
    text-decoration: none;
  }

  .breadcrumbs a:hover {
    color: var(--color-accent);
  }

  .breadcrumbs__sep {
    opacity: 0.4;
  }

  .docs-page-title {
    font-size: 2rem;
    font-weight: 800;
    margin: 0 0 0.75rem;
    color: var(--color-text);
  }

  .docs-page-lead {
    font-size: 1.0625rem;
    color: var(--color-text-muted);
    line-height: 1.7;
    margin: 0 0 2.5rem;
    max-width: 640px;
  }

  .docs-page-text {
    font-size: 0.9375rem;
    color: var(--color-text-muted);
    line-height: 1.7;
    margin: 0 0 1rem;
    max-width: 640px;
  }

  .docs-page-text code {
    background: #f1f5f9;
    padding: 0.125rem 0.375rem;
    border-radius: 4px;
    font-size: 0.8125rem;
    color: var(--color-text);
  }

  .docs-link {
    color: var(--color-accent);
    text-decoration: none;
  }

  .docs-link:hover {
    text-decoration: underline;
  }

  h2 {
    font-size: 1.375rem;
    margin: 2.5rem 0 1rem;
  }

  .docs-page-subtitle {
    font-size: 1.125rem;
    font-weight: 600;
    margin: 2rem 0 0.75rem;
    color: var(--color-text);
  }

  /* ── Callout ── */

  .callout {
    display: flex;
    gap: 0.75rem;
    background: #fefce8;
    border: 1px solid #fde68a;
    border-radius: 8px;
    padding: 1rem 1.25rem;
    margin-bottom: 1.5rem;
    font-size: 0.875rem;
    color: var(--color-text-muted);
    line-height: 1.6;
  }

  .callout__icon {
    color: #ca8a04;
    flex-shrink: 0;
    margin-top: 0.125rem;
  }

  .callout p {
    margin: 0;
  }

  /* ── Code blocks ── */

  .code-block-wrap {
    border-radius: 10px;
    overflow: hidden;
    border: 1px solid #e2e8f0;
    margin-bottom: 1.5rem;
  }

  .code-block-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    background: #f8fafc;
    padding: 0.5rem 1rem;
    border-bottom: 1px solid #e2e8f0;
  }

  .code-block-lang {
    font-size: 0.75rem;
    font-weight: 600;
    color: var(--color-text);
    text-transform: uppercase;
    letter-spacing: 0.03em;
  }

  .code-block-status {
    display: inline-flex;
    align-items: center;
    padding: 0.2rem 0.625rem;
    background: #dcfce7;
    color: #16a34a;
    font-size: 0.75rem;
    font-weight: 600;
    border-radius: 4px;
  }

  .code-block-actions {
    display: flex;
    align-items: center;
    gap: 0.5rem;
  }

  .code-block-run {
    display: inline-flex;
    align-items: center;
    gap: 0.375rem;
    padding: 0.3rem 0.625rem;
    background: var(--color-accent);
    color: #fff;
    font-size: 0.75rem;
    font-weight: 600;
    border-radius: 6px;
    text-decoration: none;
    transition: background 0.15s ease;
  }

  .code-block-run:hover {
    background: #076ed4;
  }

  .code-block-run svg {
    flex-shrink: 0;
  }

  .code-block-copy {
    background: none;
    border: none;
    cursor: pointer;
    color: var(--color-text-muted);
    padding: 0.25rem;
    border-radius: 4px;
    display: flex;
    align-items: center;
  }

  .code-block-copy:hover {
    color: var(--color-accent);
  }

  .code-block-dark {
    background: #1e293b;
    padding: 1.25rem;
    overflow-x: auto;
    margin: 0;
  }

  .code-block-dark code {
    color: #e2e8f0;
    font-size: 0.8125rem;
    line-height: 1.7;
  }

  /* ── Next steps ── */

  .next-steps-list {
    list-style: none;
    padding: 0;
    margin: 0 0 2rem;
  }

  .next-steps-list li {
    padding: 0.5rem 0;
    font-size: 0.9375rem;
    color: var(--color-text-muted);
    line-height: 1.6;
  }

  .next-steps-list li::before {
    content: '→ ';
    color: var(--color-accent);
    font-weight: 600;
  }

  .next-steps-list a {
    color: var(--color-accent);
    text-decoration: none;
    font-weight: 500;
  }

  .next-steps-list a:hover {
    text-decoration: underline;
  }
</style>

<script>
  document.querySelectorAll<HTMLButtonElement>('[data-copy-block]').forEach((btn) => {
    btn.addEventListener('click', () => {
      const blockId = btn.dataset.copyBlock!;
      const block = document.getElementById(blockId);
      if (block) {
        navigator.clipboard.writeText(block.textContent!.trim());
      }
    });
  });
</script>
