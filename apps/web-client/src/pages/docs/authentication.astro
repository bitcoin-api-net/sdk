---
import DocsLayout from '@layouts/DocsLayout.astro';

const jsExample = `const response = await fetch(
  'https://api.bitcoinapi.dev/v1/prices/current?symbol=btcusdt',
  {
    headers: {
      'Authorization': 'Bearer YOUR_API_KEY',
      'Accept': 'application/json',
    },
  }
);

const data = await response.json();
console.log(data);`;
---

<DocsLayout>
  <nav class="breadcrumbs" aria-label="Breadcrumb">
    <a href="/docs">Docs</a>
    <span class="breadcrumbs__sep">›</span>
    <span>Authentication</span>
  </nav>

  <h1 class="docs-page-title">Authentication</h1>
  <p class="docs-page-lead">
    All API endpoints require authentication. Bitcoin API uses Bearer token authentication over HTTPS to secure your
    requests.
  </p>

  <h2 id="how-it-works">How It Works</h2>
  <p class="docs-page-text">
    After creating an account, you receive an API key. Include this key in the <code>Authorization</code> header of every
    request using the <code>Bearer</code> scheme.
  </p>

  <div class="code-block-wrap">
    <div class="code-block-header">
      <span class="code-block-lang">HTTP Header</span>
    </div>
    <pre class="code-block-dark"><code>Authorization: Bearer YOUR_API_KEY</code></pre>
  </div>

  <h2 id="example-request">Example Request</h2>
  <p class="docs-page-text">Here's a complete authenticated request using curl:</p>

  <div class="code-block-wrap">
    <div class="code-block-header">
      <span class="code-block-lang">CURL</span>
      <button class="code-block-copy" data-copy-block="auth-example" aria-label="Copy code">
        <svg
          width="14"
          height="14"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="2"
          stroke-linecap="round"
          stroke-linejoin="round"
          ><rect x="9" y="9" width="13" height="13" rx="2"></rect><path
            d="M5 15H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h9a2 2 0 0 1 2 2v1"></path></svg
        >
      </button>
    </div>
    <pre
      class="code-block-dark"
      id="auth-example"><code>curl https://api.bitcoinapi.dev/v1/prices/current?symbol=btcusdt \
  -H "Authorization: Bearer sk_live_abc123..." \
  -H "Accept: application/json"</code></pre>
  </div>

  <p class="docs-page-text">And the same request in JavaScript:</p>

  <div class="code-block-wrap">
    <div class="code-block-header">
      <span class="code-block-lang">JavaScript</span>
    </div>
    <pre class="code-block-dark"><code set:text={jsExample} /></pre>
  </div>

  <h2 id="error-responses">Error Responses</h2>
  <p class="docs-page-text">If authentication fails, the API returns an error with a descriptive message:</p>

  <div class="error-table-wrap">
    <table class="error-table">
      <thead>
        <tr>
          <th>Status</th>
          <th>Code</th>
          <th>Description</th>
        </tr>
      </thead>
      <tbody>
        <tr>
          <td><span class="status-badge status-badge--error">401</span></td>
          <td><code>UNAUTHORIZED</code></td>
          <td>Missing or invalid API key</td>
        </tr>
        <tr>
          <td><span class="status-badge status-badge--error">403</span></td>
          <td><code>FORBIDDEN</code></td>
          <td>API key does not have access to this resource</td>
        </tr>
      </tbody>
    </table>
  </div>

  <h2 id="security-best-practices">Security Best Practices</h2>
  <ul class="best-practices">
    <li>
      <strong>Never expose your API key in client-side code.</strong> Always call the API from your server or a serverless
      function.
    </li>
    <li>
      <strong>Use environment variables</strong> to store your API key instead of hardcoding it in your source code.
    </li>
    <li>
      <strong>Rotate your key</strong> if you suspect it has been compromised. You can regenerate it from your profile dashboard.
    </li>
    <li>
      <strong>Use HTTPS only.</strong> All API requests must be made over HTTPS. HTTP requests will be rejected.
    </li>
  </ul>

  <h2 id="next-steps">Next Steps</h2>
  <ul class="next-steps-list">
    <li><a href="/docs/price/current">Current Price API</a> — Full endpoint reference</li>
    <li><a href="/docs/quickstart">Quickstart Guide</a> — Make your first request step by step</li>
  </ul>
</DocsLayout>

<style>
  .breadcrumbs {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    font-size: 0.8125rem;
    color: var(--color-text-muted);
    margin-bottom: 1.5rem;
  }

  .breadcrumbs a {
    color: var(--color-text-muted);
    text-decoration: none;
  }

  .breadcrumbs a:hover {
    color: var(--color-accent);
  }

  .breadcrumbs__sep {
    opacity: 0.4;
  }

  .docs-page-title {
    font-size: 2rem;
    font-weight: 800;
    margin: 0 0 0.75rem;
    color: var(--color-text);
  }

  .docs-page-lead {
    font-size: 1.0625rem;
    color: var(--color-text-muted);
    line-height: 1.7;
    margin: 0 0 2.5rem;
    max-width: 640px;
  }

  .docs-page-text {
    font-size: 0.9375rem;
    color: var(--color-text-muted);
    line-height: 1.7;
    margin: 0 0 1rem;
    max-width: 640px;
  }

  .docs-page-text code {
    background: #f1f5f9;
    padding: 0.125rem 0.375rem;
    border-radius: 4px;
    font-size: 0.8125rem;
    color: var(--color-text);
  }

  h2 {
    font-size: 1.375rem;
    margin: 2.5rem 0 1rem;
  }

  /* ── Code blocks ── */

  .code-block-wrap {
    border-radius: 10px;
    overflow: hidden;
    border: 1px solid #e2e8f0;
    margin-bottom: 1.5rem;
  }

  .code-block-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    background: #f8fafc;
    padding: 0.5rem 1rem;
    border-bottom: 1px solid #e2e8f0;
  }

  .code-block-lang {
    font-size: 0.75rem;
    font-weight: 600;
    color: var(--color-text);
    text-transform: uppercase;
    letter-spacing: 0.03em;
  }

  .code-block-copy {
    background: none;
    border: none;
    cursor: pointer;
    color: var(--color-text-muted);
    padding: 0.25rem;
    border-radius: 4px;
    display: flex;
    align-items: center;
  }

  .code-block-copy:hover {
    color: var(--color-accent);
  }

  .code-block-dark {
    background: #1e293b;
    padding: 1.25rem;
    overflow-x: auto;
    margin: 0;
  }

  .code-block-dark code {
    color: #e2e8f0;
    font-size: 0.8125rem;
    line-height: 1.7;
  }

  /* ── Error table ── */

  .error-table-wrap {
    overflow-x: auto;
    margin-bottom: 2rem;
  }

  .error-table {
    width: 100%;
    border-collapse: collapse;
    font-size: 0.875rem;
  }

  .error-table th {
    text-align: left;
    padding: 0.75rem 1rem;
    background: #f8fafc;
    border-bottom: 2px solid #e2e8f0;
    font-weight: 600;
    color: var(--color-text);
  }

  .error-table td {
    padding: 0.75rem 1rem;
    border-bottom: 1px solid #f1f5f9;
    color: var(--color-text-muted);
    vertical-align: top;
  }

  .error-table code {
    background: #f1f5f9;
    padding: 0.125rem 0.375rem;
    border-radius: 4px;
    font-size: 0.8125rem;
    color: var(--color-text);
  }

  .status-badge {
    display: inline-flex;
    align-items: center;
    padding: 0.2rem 0.5rem;
    font-size: 0.75rem;
    font-weight: 600;
    border-radius: 4px;
  }

  .status-badge--error {
    background: #fee2e2;
    color: #dc2626;
  }

  /* ── Best practices ── */

  .best-practices {
    list-style: none;
    padding: 0;
    margin: 0 0 2rem;
  }

  .best-practices li {
    position: relative;
    padding: 0.625rem 0 0.625rem 1.5rem;
    font-size: 0.9375rem;
    color: var(--color-text-muted);
    line-height: 1.6;
  }

  .best-practices li::before {
    content: '';
    position: absolute;
    left: 0;
    top: 1rem;
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background: var(--color-accent);
  }

  .best-practices strong {
    color: var(--color-text);
  }

  /* ── Next steps ── */

  .next-steps-list {
    list-style: none;
    padding: 0;
    margin: 0 0 2rem;
  }

  .next-steps-list li {
    padding: 0.5rem 0;
    font-size: 0.9375rem;
    color: var(--color-text-muted);
    line-height: 1.6;
  }

  .next-steps-list li::before {
    content: '→ ';
    color: var(--color-accent);
    font-weight: 600;
  }

  .next-steps-list a {
    color: var(--color-accent);
    text-decoration: none;
    font-weight: 500;
  }

  .next-steps-list a:hover {
    text-decoration: underline;
  }
</style>

<script>
  document.querySelectorAll<HTMLButtonElement>('[data-copy-block]').forEach((btn) => {
    btn.addEventListener('click', () => {
      const blockId = btn.dataset.copyBlock!;
      const block = document.getElementById(blockId);
      if (block) {
        navigator.clipboard.writeText(block.textContent!.trim());
      }
    });
  });
</script>
