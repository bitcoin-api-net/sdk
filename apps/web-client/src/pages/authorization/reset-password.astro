---
import PublicPagesLayout from '@layouts/PublicPagesLayout.astro';
import ResetPasswordForm from '@components/reset-password/ResetPasswordForm.vue';
import IconChevronLeft from '@icons/IconChevronLeft.astro';
---

<PublicPagesLayout title="Bitcoin API - Reset Password">
  <main class="flex-grow flex items-center justify-center p-4 lg:p-6">
    <div class="reset-card w-full max-w-[596px] bg-white rounded-[24px] border border-[#f3f4f6] p-8 lg:p-[60px_60px_40px_60px] flex flex-col items-center">

      <h1 class="text-[32px] lg:text-[40px] leading-tight font-bold text-[#323743] text-center mb-4">
        Reset your password
      </h1>
      <p class="text-[#636B7A] text-base leading-6 text-center mb-10 max-w-[430px]">
        Enter your new password below
      </p>

      <ResetPasswordForm client:load />

      <a
        href="/authorization/sign-in"
        class="mt-4 h-[52px] px-6 flex items-center justify-center gap-2 text-[#171a1f] font-medium hover:bg-gray-50 rounded-[26px] transition-brand group"
      >
        <IconChevronLeft class="w-5 h-5 text-[#171a1f] group-hover:-translate-x-1 transition-transform" />
        <span>Back to Login</span>
      </a>
    </div>
  </main>
</PublicPagesLayout>

<style>
  .reset-card {
    box-shadow: 0px 8px 30px 0px rgba(0, 0, 0, 0.04);
  }

  .transition-brand {
    transition: all 0.2s cubic-bezier(0.4, 0, 0.2, 1);
  }

  @media (max-width: 400px) {
    h1 {
      font-size: 24px;
    }
    .p-8 {
      padding: 1.5rem;
    }
  }
</style>
