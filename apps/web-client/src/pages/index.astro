---
import PublicPagesLayout from '@layouts/PublicPagesLayout.astro';
---

<PublicPagesLayout
  title="BitAPI — Bitcoin API for Developers"
  description="Access comprehensive Bitcoin data with the most comfortable API. Pay only for what you use. No hidden fees."
>
  <main>
    <section class="hero">
      <div class="container">
        <span class="hero__badge">⚡ The Most Complete Bitcoin API</span>
        <h1 class="hero__title">
          Bitcoin API Built for <span class="hero__title-accent">Developers</span>
        </h1>
        <p class="hero__description">
          Access comprehensive Bitcoin data with the most comfortable API. Pay only for the endpoint
          groups you use. No hidden fees, no complexity.
        </p>
        <div class="hero__actions">
          <a href="/signup" class="btn btn--primary">
            Start Building
            <span class="hero__arrow">→</span>
          </a>
          <a href="/docs" class="btn btn--secondary">
            <span class="hero__code-icon">&lt;/&gt;</span>
            View Documentation
          </a>
        </div>
      </div>
    </section>

    <section class="stats">
      <div class="container">
        <div class="stats__grid">
          <div class="stats__item">
            <span class="stats__value">99.9%</span>
            <span class="stats__label">Uptime</span>
          </div>
          <div class="stats__item">
            <span class="stats__value">&lt;100ms</span>
            <span class="stats__label">Response Time</span>
          </div>
          <div class="stats__item">
            <span class="stats__value">50+</span>
            <span class="stats__label">Endpoints</span>
          </div>
        </div>
      </div>
    </section>

    <section class="why-choose">
      <div class="container">
        <h2 class="why-choose__title">Why Choose BitAPI?</h2>
        <p class="why-choose__text">
          Built by developers for developers. Get the most comprehensive Bitcoin API with flexible
          pricing.
        </p>
      </div>
    </section>

    <section class="quick-start">
      <div class="container">
        <h2 class="section-title">Quick Start</h2>
        <p class="quick-start__text">Get Bitcoin data in seconds. Just add your API key and make a request.</p>
        <div class="quick-start__code">
          <pre><code>curl -X GET "https://api.bitcoin-api.net/v1/blocks/latest" \
  -H "Authorization: Bearer YOUR_API_KEY"</code></pre>
        </div>
      </div>
    </section>

    <section class="endpoints">
      <div class="container">
        <h2 class="section-title">API Endpoints</h2>
        <p class="endpoints__intro">Comprehensive data across the Bitcoin ecosystem.</p>
        <ul class="endpoints__list">
          <li><strong>Blocks</strong> — Latest blocks, block details, orphan blocks</li>
          <li><strong>Mempool</strong> — Unconfirmed transactions, fees</li>
          <li><strong>Addresses</strong> — Balance, history, UTXOs</li>
          <li><strong>Transactions</strong> — Decode, broadcast, fee estimates</li>
          <li><strong>Market</strong> — Price, volume, OHLCV data</li>
        </ul>
      </div>
    </section>

    <section class="cta">
      <div class="container">
        <h2 class="cta__title">Ready to build?</h2>
        <p class="cta__text">Start with a free API key. No credit card required.</p>
        <a href="/signup" class="btn btn--primary">
          Get Your API Key
          <span class="hero__arrow">→</span>
        </a>
      </div>
    </section>
  </main>
</PublicPagesLayout>

<style lang="scss">
  .container {
    max-width: 1200px;
    margin: 0 auto;
    padding: 0 1.5rem;
  }

  .hero {
    padding: 5rem 0 6rem;
    text-align: center;
  }

  .hero__badge {
    display: inline-block;
    padding: 0.375rem 0.875rem;
    background: rgba(249, 115, 22, 0.15);
    color: #ea580c;
    font-size: 0.875rem;
    font-weight: 600;
    border-radius: 9999px;
    margin-bottom: 1.5rem;
  }

  .hero__title {
    font-size: clamp(2rem, 5vw, 3.5rem);
    font-weight: 700;
    line-height: 1.2;
    margin: 0 0 1.5rem;
  }

  .hero__title-accent {
    color: #f97316;
  }

  .hero__description {
    font-size: 1.125rem;
    color: #666;
    max-width: 36rem;
    margin: 0 auto 2.5rem;
    line-height: 1.7;
  }

  .hero__actions {
    display: flex;
    flex-wrap: wrap;
    gap: 1rem;
    justify-content: center;
  }

  .hero__arrow {
    margin-left: 0.375rem;
  }

  .hero__code-icon {
    margin-right: 0.5rem;
    opacity: 0.8;
  }

  .stats {
    padding: 4rem 0;
    border-top: 1px solid #eee;
  }

  .stats__grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
    gap: 2rem;
    text-align: center;
  }

  .stats__item {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }

  .stats__value {
    font-size: 2.5rem;
    font-weight: 700;
    color: #1a1a1a;
  }

  .stats__label {
    font-size: 1rem;
    color: #666;
  }

  .why-choose {
    padding: 5rem 0;
    border-top: 1px solid #eee;
    text-align: center;
  }

  .why-choose__title {
    font-size: 2rem;
    font-weight: 700;
    margin: 0 0 1rem;
  }

  .why-choose__text {
    font-size: 1.125rem;
    color: #666;
    max-width: 32rem;
    margin: 0 auto;
    line-height: 1.7;
  }

  .section-title {
    font-size: 1.75rem;
    font-weight: 700;
    margin: 0 0 1rem;
    text-align: center;
  }

  .quick-start {
    padding: 5rem 0;
    border-top: 1px solid #eee;
  }

  .quick-start__text {
    font-size: 1.125rem;
    color: #666;
    text-align: center;
    margin: 0 0 1.5rem;
  }

  .quick-start__code {
    max-width: 36rem;
    margin: 0 auto;
    background: #1a1a1a;
    color: #e5e5e5;
    border-radius: 0.5rem;
    padding: 1.25rem 1.5rem;
    overflow-x: auto;
  }

  .quick-start__code pre {
    margin: 0;
    font-family: ui-monospace, monospace;
    font-size: 0.875rem;
    line-height: 1.6;
  }

  .quick-start__code code {
    white-space: pre-wrap;
    word-break: break-all;
  }

  .endpoints {
    padding: 5rem 0;
    border-top: 1px solid #eee;
  }

  .endpoints__intro {
    font-size: 1.125rem;
    color: #666;
    text-align: center;
    margin: 0 0 2rem;
  }

  .endpoints__list {
    max-width: 32rem;
    margin: 0 auto;
    padding: 0;
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
  }

  .endpoints__list li {
    padding: 0.75rem 1rem;
    background: #f8f8f8;
    border-radius: 0.375rem;
    font-size: 1rem;
  }

  .endpoints__list strong {
    color: var(--color-accent);
    margin-right: 0.5rem;
  }

  .cta {
    padding: 5rem 0 6rem;
    border-top: 1px solid #eee;
    text-align: center;
  }

  .cta__title {
    font-size: 1.75rem;
    font-weight: 700;
    margin: 0 0 0.5rem;
  }

  .cta__text {
    font-size: 1.125rem;
    color: #666;
    margin: 0 0 1.5rem;
  }

  @media (max-width: 768px) {
    .hero {
      padding: 3rem 0 4rem;
    }

    .hero__actions {
      flex-direction: column;
    }

    .hero__actions .btn {
      width: 100%;
      justify-content: center;
    }

    .stats {
      padding: 3rem 0;
    }

    .stats__grid {
      gap: 1.5rem;
    }

    .stats__value {
      font-size: 2rem;
    }

    .why-choose,
    .quick-start,
    .endpoints {
      padding: 3rem 0;
    }

    .quick-start__code {
      padding: 1rem;
    }

    .quick-start__code code {
      font-size: 0.8125rem;
    }

    .cta {
      padding: 3rem 0 4rem;
    }
  }
</style>
