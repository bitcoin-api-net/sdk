---
import PublicPagesLayout from '@layouts/PublicPagesLayout.astro';
import IconBolt from '@icons/IconBolt.astro';
import IconArrowRight from '@icons/IconArrowRight.astro';
import IconCheckCircle from '@icons/IconCheckCircle.astro';
import IconRealtime from '@icons/IconRealtime.astro';
import IconEasyStart from '@icons/IconEasyStart.astro';
import IconShield from '@icons/IconShield.astro';
import IconGlobe from '@icons/IconGlobe.astro';
import IconCode from '@icons/IconCode.astro';
import IconTerminal from '@icons/IconTerminal.astro';
import IconDashboard from '@icons/IconDashboard.astro';
import IconCommunity from '@icons/IconCommunity.astro';

const heroCode = `<span class="syntax-keyword">async function</span> <span class="syntax-function">getBitcoinPrice</span>() {
  <span class="syntax-keyword">const</span> <span class="syntax-variable">response</span> <span class="syntax-operator">=</span> <span class="syntax-keyword">await</span> <span class="syntax-function">fetch</span>(<span class="syntax-string">"https://bitcoin-api/api/v1/prices/current"</span>, {
    headers: {
      <span class="syntax-string">"Content-Type"</span>: <span class="syntax-string">"application/json"</span>,
      <span class="syntax-string">"Authorization"</span>: <span class="syntax-string">"Bearer sk_live_..."</span>
    }
  });
  <span class="syntax-keyword">const</span> <span class="syntax-variable">data</span> <span class="syntax-operator">=</span> <span class="syntax-keyword">await</span> <span class="syntax-variable">response</span>.<span class="syntax-function">json</span>();
  <span class="syntax-function">console</span>.<span class="syntax-function">log</span>(<span class="syntax-variable">data</span>);
}`;

const heroOutput = `<span class="syntax-comment">// Output: { price: 65432.10, currency: "USD" ... }</span>`;

const integrationCode = `<span class="syntax-keyword">const</span> <span class="syntax-variable">response</span> <span class="syntax-operator">=</span> <span class="syntax-keyword">await</span> <span class="syntax-function">fetch</span>(<span class="syntax-string">'https://api.bitapi.com/v1/transactions'</span>, {
  <span class="syntax-variable">method</span>: <span class="syntax-string">'GET'</span>,
  <span class="syntax-variable">headers</span>: {
    <span class="syntax-string">'Authorization'</span>: <span class="syntax-string">'Bearer sk_live_5jM...'</span>,
    <span class="syntax-string">'Content-Type'</span>: <span class="syntax-string">'application/json'</span>
  }
});

<span class="syntax-keyword">const</span> <span class="syntax-variable">data</span> <span class="syntax-operator">=</span> <span class="syntax-keyword">await</span> <span class="syntax-variable">response</span>.<span class="syntax-function">json</span>();
<span class="syntax-function">console</span>.<span class="syntax-function">log</span>(<span class="syntax-variable">data</span>);

<span class="syntax-comment">// Response</span>
{
  <span class="syntax-string">"id"</span>: <span class="syntax-string">"tx_1N5..."</span>,
  <span class="syntax-string">"amount"</span>: <span class="syntax-number">0.054</span>,
  <span class="syntax-string">"currency"</span>: <span class="syntax-string">"btc"</span>,
  <span class="syntax-string">"status"</span>: <span class="syntax-string">"confirmed"</span>,
  <span class="syntax-string">"network_fee"</span>: <span class="syntax-number">0.000014</span>
}`;
---

<PublicPagesLayout
  title="Bitcoin API — The Most Intuitive Bitcoin API"
  description="Experience unparalleled speed and reliability. Build the future of finance with the most developer-friendly tools available.">
  <main>
    <!-- Hero -->
    <section class="relative pt-16 pb-24 lg:pt-32 lg:pb-40 overflow-hidden">
      <div
        class="absolute top-[-200px] right-[-100px] w-[800px] h-[800px] bg-[#0983FD]/5 rounded-full blur-[64px] -z-10">
      </div>

      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="grid grid-cols-1 lg:grid-cols-2 gap-16 items-center">
          <div class="flex flex-col items-start">
            <div
              class="inline-flex items-center px-3 py-1 rounded-full bg-[#DBEAFE] text-[#1D4ED8] text-xs font-semibold mb-8">
              Latest version - v1
            </div>
            <h1 class="text-5xl lg:text-6xl font-extrabold leading-[1.1] tracking-tight mb-6">
              The Most Intuitive<br />
              <span class="text-[#0983FD]">Bitcoin API</span>
            </h1>
            <p class="text-lg lg:text-xl text-[#565d6d] leading-relaxed mb-10 max-w-xl">
              Experience unparalleled speed and reliability. Build the future of finance with the most
              developer-friendly tools available on the market—now completely free for everyone to start.
            </p>
            <div class="flex flex-wrap gap-4 mb-12">
              <a
                href="/authorization/sign-up"
                data-auth-link
                class="bg-[#0983FD] text-white px-8 py-3 rounded-md text-base font-medium flex items-center gap-2 shadow-[0_4px_7px_rgba(9,131,253,0.25)] hover:bg-[#076ed4]">
                <IconBolt class="w-4 h-4" />
                Get API Key
              </a>
              <a
                href="/docs"
                class="bg-transparent text-[#171a1f] px-8 py-3 rounded-md text-base font-medium flex items-center gap-2 hover:bg-gray-50">
                Read Documentation
                <IconArrowRight class="w-4 h-4" />
              </a>
            </div>
            <div class="flex items-center gap-2 text-sm">
              <IconCheckCircle class="w-4 h-4 text-[#22C55E]" />
              <span>99.99% Uptime</span>
            </div>
          </div>

          <div class="relative">
            <div class="bg-[#0F172A] rounded-2xl p-8 code-window-shadow border border-white/10">
              <pre class="text-sm leading-6 overflow-x-auto"><code class="text-[#CBD5E1]" set:html={heroCode} /></pre>
              <hr class="border-white/10 my-6" />
              <pre class="text-sm leading-6"><code class="text-[#CBD5E1]" set:html={heroOutput} /></pre>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- Features -->
    <section class="bg-[#fafafb] py-24">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="text-center mb-16">
          <div
            class="inline-flex items-center px-3 py-1 rounded-full bg-[#0983FD]/5 border border-[#0983FD]/20 text-[#0983FD] text-xs font-semibold mb-4">
            Deploy Faster
          </div>
          <h2 class="text-3xl lg:text-4xl font-bold mb-4">Everything you need to build crypto apps</h2>
          <p class="text-lg text-[#565d6d] max-w-3xl mx-auto">
            Designed for developers who need power and simplicity. We handle the complexity of the blockchain so you
            don't have to.
          </p>
        </div>

        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
          <div class="bg-white p-8 rounded-2xl shadow-sm border border-[#dee1e6]/50 hover:shadow-md transition-shadow">
            <div class="w-12 h-12 bg-[#EFF6FF] rounded-xl flex items-center justify-center mb-6">
              <IconRealtime class="w-6 h-6 text-[#0983FD]" />
            </div>
            <h3 class="text-xl font-semibold mb-4">Real-time Data</h3>
            <p class="text-[#565d6d] leading-relaxed">
              Most data is taken from direct source i.e. Centralized/Decentralized exchanges and blockchain
            </p>
          </div>
          <div class="bg-white p-8 rounded-2xl shadow-sm border border-[#dee1e6]/50 hover:shadow-md transition-shadow">
            <div class="w-12 h-12 bg-[#EFF6FF] rounded-xl flex items-center justify-center mb-6">
              <IconEasyStart class="w-6 h-6 text-[#0983FD]" />
            </div>
            <h3 class="text-xl font-semibold mb-4">Easy to start</h3>
            <p class="text-[#565d6d] leading-relaxed">
              All endpoints are well documented and with examples of implementation
            </p>
          </div>
          <div class="bg-white p-8 rounded-2xl shadow-sm border border-[#dee1e6]/50 hover:shadow-md transition-shadow">
            <div class="w-12 h-12 bg-[#EFF6FF] rounded-xl flex items-center justify-center mb-6">
              <IconShield class="w-6 h-6 text-[#0983FD]" />
            </div>
            <h3 class="text-xl font-semibold mb-4">Sustainable</h3>
            <p class="text-[#565d6d] leading-relaxed">
              Availability is one of primary goals. We monitor each of our endpoints and swap data source in case of
              source failure.
            </p>
          </div>
        </div>
      </div>
    </section>

    <!-- Integration -->
    <section class="py-24 lg:py-32">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="grid grid-cols-1 lg:grid-cols-2 gap-20 items-center">
          <div>
            <span class="text-[#0983FD] font-semibold text-base mb-4 block">Integration</span>
            <h2 class="text-3xl lg:text-4xl font-bold mb-6">Works with your stack</h2>
            <p class="text-lg text-[#565d6d] mb-12 max-w-lg">
              Whether you're building a wallet, an exchange, or a payment processor, our API fits right into your
              existing workflow.
            </p>

            <div class="space-y-8">
              <div class="flex gap-4">
                <div class="flex-shrink-0 w-10 h-10 bg-[#DBEAFE]/50 rounded-lg flex items-center justify-center">
                  <IconGlobe class="w-5 h-5 text-[#0983FD]" />
                </div>
                <div>
                  <h4 class="text-base font-semibold text-[#171a1f] mb-1">RESTful API</h4>
                  <p class="text-sm text-[#565d6d]">
                    Standard HTTP methods and predictable resource URLs. Compatible with any HTTP client.
                  </p>
                </div>
              </div>
              <div class="flex gap-4">
                <div class="flex-shrink-0 w-10 h-10 bg-[#DBEAFE]/50 rounded-lg flex items-center justify-center">
                  <IconCode class="w-5 h-5 text-[#0983FD]" />
                </div>
                <div>
                  <h4 class="text-base font-semibold text-[#171a1f] mb-1">SDKs available</h4>
                  <p class="text-sm text-[#565d6d]">
                    Official libraries for Python, Node.js, Go, and Ruby to get you up and running in minutes.
                  </p>
                </div>
              </div>
              <div class="flex gap-4">
                <div class="flex-shrink-0 w-10 h-10 bg-[#DBEAFE]/50 rounded-lg flex items-center justify-center">
                  <IconTerminal class="w-5 h-5 text-[#0983FD]" />
                </div>
                <div>
                  <h4 class="text-base font-semibold text-[#171a1f] mb-1">CLI Tool</h4>
                  <p class="text-sm text-[#565d6d]">
                    Test endpoints directly from your terminal before writing a single line of code.
                  </p>
                </div>
              </div>
            </div>
          </div>

          <div class="bg-[#0F172A] rounded-2xl overflow-hidden code-window-shadow border border-white/10">
            <div class="bg-white/5 px-4 py-3 flex items-center justify-between border-b border-white/10">
              <div class="flex gap-2">
                <div class="w-3 h-3 rounded-full bg-[#FF5F56]"></div>
                <div class="w-3 h-3 rounded-full bg-[#FFBD2E]"></div>
                <div class="w-3 h-3 rounded-full bg-[#27C93F]"></div>
              </div>
              <span class="text-[12px] font-medium text-[#94A3B8]">GET /v1/transactions</span>
              <div class="w-12"></div>
            </div>
            <div class="p-6 overflow-x-auto">
              <pre class="text-sm leading-6"><code class="text-[#CBD5E1]" set:html={integrationCode} /></pre>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- CTA -->
    <section class="bg-[#0F1729] py-24 relative overflow-hidden">
      <div class="absolute top-[-100px] right-[-100px] w-[400px] h-[400px] bg-[#0983FD]/10 rounded-full blur-[64px]">
      </div>
      <div class="absolute bottom-[-100px] left-[-100px] w-[300px] h-[300px] bg-[#3B82F6]/10 rounded-full blur-[64px]">
      </div>

      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 relative z-10">
        <div class="grid grid-cols-1 lg:grid-cols-2 gap-16 items-center">
          <div>
            <h2 class="text-3xl lg:text-4xl font-bold text-white mb-6">Ready to build the future?</h2>
            <p class="text-lg text-[#CBD5E1] mb-10 max-w-lg">
              Join thousands of developers building the next generation of financial applications with Bitcoin API.
              Start building for free today.
            </p>
            <div class="flex flex-wrap gap-4">
              <a
                href="/authorization/sign-up"
                data-auth-link
                class="bg-[#0983FD] text-white px-8 py-3 rounded-md text-base font-medium shadow-sm hover:bg-[#076ed4]">
                Get started today
              </a>
              <a
                href="/pricing"
                class="bg-white/5 border border-white/20 text-white px-8 py-3 rounded-md text-base font-medium hover:bg-white/10">
                Pricing
              </a>
            </div>
          </div>

          <div class="grid grid-cols-1 sm:grid-cols-2 gap-6">
            <div class="bg-white/5 backdrop-blur-sm border border-white/10 p-8 rounded-2xl">
              <div class="w-10 h-10 bg-[#0983FD]/20 rounded-lg flex items-center justify-center mb-6">
                <IconDashboard class="w-5 h-5 text-white" />
              </div>
              <h4 class="text-white font-semibold mb-2">Weekly updates</h4>
              <p class="text-sm text-[#94A3B8]">We ship new features and improvements every week.</p>
            </div>
            <div class="bg-white/5 backdrop-blur-sm border border-white/10 p-8 rounded-2xl">
              <div class="w-10 h-10 bg-[#0983FD]/20 rounded-lg flex items-center justify-center mb-6">
                <IconCommunity class="w-5 h-5 text-white" />
              </div>
              <h4 class="text-white font-semibold mb-2">Active community</h4>
              <p class="text-sm text-[#94A3B8]">Join our Discord and connect with other builders.</p>
            </div>
          </div>
        </div>
      </div>
    </section>
  </main>
</PublicPagesLayout>

<script>
  import { userStore } from '@stores/auth';

  userStore.subscribe((user) => {
    const href = user ? '/profile/home' : '/authorization/sign-up';
    document.querySelectorAll<HTMLAnchorElement>('[data-auth-link]').forEach((link) => {
      link.href = href;
    });
  });
</script>
