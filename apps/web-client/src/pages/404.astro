---
import PublicPagesLayout from '@layouts/PublicPagesLayout.astro';
---

<PublicPagesLayout title="404 — Bitcoin API" description="Page not found. Return to Bitcoin API home.">
  <main class="py-24 md:py-32 text-center">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <p class="text-7xl font-bold text-[#0983FD] mb-2 leading-none">404</p>
      <h1 class="text-2xl font-bold mb-4">Page not found</h1>
      <p class="text-lg text-[#565d6d] max-w-md mx-auto mb-8 leading-relaxed">
        The page you're looking for doesn't exist or has been moved.
      </p>
      <div class="flex flex-wrap gap-4 justify-center">
        <a href="/" class="bg-[#0983FD] text-white px-6 py-3 rounded-md text-sm font-semibold shadow-sm hover:bg-[#076ed4]">
          Back to Home →
        </a>
        <a href="/docs" class="bg-transparent text-[#171a1f] px-6 py-3 rounded-md text-sm font-medium border border-[#dee1e6] hover:bg-gray-50">
          View Docs
        </a>
      </div>
    </div>
  </main>
</PublicPagesLayout>
