---
import PublicPagesLayout from '@layouts/PublicPagesLayout.astro';
import { getCollection } from 'astro:content';
import { getRelativeLocaleUrl } from 'astro:i18n';
import { type Locale } from 'src/types';
import { i18nService } from 'src/services/i18n';

export async function getStaticPaths() {
  const collection = await getCollection('ui');
  return collection.map((page) => ({
    params: { lang: i18nService.collectionIdToLocale(page.id) },
    props: page,
  }));
}
const lang = Astro.currentLocale as Locale;
const page = Astro.props;
const pageData = page.data;
---

<PublicPagesLayout title="404 — Bitcoin API" description="Page not found. Return to Bitcoin API home.">
  <main class="page-404">
    <div class="container">
      <p class="page-404__code">404</p>
      <h1 class="page-404__title">Not Found</h1>
      <p class="page-404__text">
        {pageData.thisAddressDoesntExistInOurMempool}
      </p>
      <div class="page-404__actions">
        <a href={getRelativeLocaleUrl(lang, '/')} class="btn btn--primary">
          {pageData.backToHome}
          <span class="page-404__arrow">→</span>
        </a>
        <a href={getRelativeLocaleUrl(lang, '/docs')} class="btn btn--secondary">{pageData.viewDocs}</a>
      </div>
    </div>
  </main>
</PublicPagesLayout>

<style lang="scss">
  .container {
    max-width: 1200px;
    margin: 0 auto;
    padding: 0 1.5rem;
  }

  .page-404 {
    padding: 6rem 0;
    text-align: center;
  }

  .page-404__code {
    font-size: 4rem;
    font-weight: 700;
    color: var(--color-accent);
    margin: 0 0 0.5rem;
    line-height: 1;
  }

  .page-404__title {
    font-size: 1.5rem;
    font-weight: 700;
    margin: 0 0 1rem;
  }

  .page-404__text {
    font-size: 1.125rem;
    color: var(--color-text-muted);
    max-width: 28rem;
    margin: 0 auto 2rem;
    line-height: 1.7;
  }

  .page-404__actions {
    display: flex;
    flex-wrap: wrap;
    gap: 1rem;
    justify-content: center;
  }

  .page-404__arrow {
    margin-left: 0.375rem;
  }

  @media (max-width: 768px) {
    .page-404 {
      padding: 4rem 0;
    }

    .page-404__code {
      font-size: 3rem;
    }

    .page-404__actions {
      flex-direction: column;
    }

    .page-404__actions .btn {
      width: 100%;
      justify-content: center;
    }
  }
</style>
