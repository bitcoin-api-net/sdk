---
import PublicPagesLayout from '@layouts/PublicPagesLayout.astro';
import { getCollection } from 'astro:content';
import { getLocaleByPath, getRelativeLocaleUrl } from 'astro:i18n';
import { type Locale } from '@i18n/types';
import { getLangFromCollectionEntry } from '@i18n/utils';

export async function getStaticPaths() {
  const collection = await getCollection('home');
  const pages = collection.map((page) => ({
    params: { lang: getLangFromCollectionEntry(page) },
    props: page,
  }));
  return pages;
}
const lang = Astro.currentLocale as Locale;
const page = Astro.props;
---

<PublicPagesLayout title={page.data.title} description={page.data.description}>
  <main>
    <section class="hero">
      <div class="container">
        <span class="hero__badge">{page.data.hero.badge}</span>
        <h1 class="hero__title">
          {page.data.hero.title}
          <span class="hero__title-accent">{page.data.hero.titleAccent}</span>
        </h1>
        <p class="hero__description">{page.data.hero.description}</p>
        <div class="hero__actions">
          <a href={getRelativeLocaleUrl(lang, '/signup')} class="btn btn--primary">
            {page.data.hero.ctaPrimary}
            <span class="hero__arrow">→</span>
          </a>
          <a href={getRelativeLocaleUrl(lang, '/docs')} class="btn btn--secondary">
            <span class="hero__code-icon">&lt;/&gt;</span>
            {page.data.hero.ctaSecondary}
          </a>
        </div>
      </div>
    </section>

    <section class="stats">
      <div class="container">
        <div class="stats__grid">
          {
            page.data.stats.map((item) => (
              <div class="stats__item">
                <span class="stats__value">{item.value}</span>
                <span class="stats__label">{item.label}</span>
              </div>
            ))
          }
        </div>
      </div>
    </section>

    <section class="why-choose">
      <div class="container">
        <h2 class="why-choose__title">{page.data.whyChoose.title}</h2>
        <p class="why-choose__text">{page.data.whyChoose.text}</p>
      </div>
    </section>

    <section class="quick-start">
      <div class="container">
        <h2 class="section-title">{page.data.quickStart.title}</h2>
        <p class="quick-start__text">{page.data.quickStart.text}</p>
        <div class="quick-start__code">
          <pre><code>{page.data.quickStart.code}</code></pre>
        </div>
      </div>
    </section>

    <section class="endpoints">
      <div class="container">
        <h2 class="section-title">{page.data.endpoints.title}</h2>
        <p class="endpoints__intro">{page.data.endpoints.intro}</p>
        <ul class="endpoints__list">
          {
            page.data.endpoints.items.map((item) => (
              <li>
                <strong>{item.category}</strong> — {item.description}
              </li>
            ))
          }
        </ul>
      </div>
    </section>

    <section class="cta">
      <div class="container">
        <h2 class="cta__title">{page.data.cta.title}</h2>
        <p class="cta__text">{page.data.cta.text}</p>
        <a href={getRelativeLocaleUrl(lang, '/signup')} class="btn btn--primary">
          {page.data.cta.buttonText}
          <span class="hero__arrow">→</span>
        </a>
      </div>
    </section>
  </main>
</PublicPagesLayout>

<style lang="scss">
  .container {
    max-width: 1200px;
    margin: 0 auto;
    padding: 0 1.5rem;
  }

  .hero {
    padding: 5rem 0 6rem;
    text-align: center;
  }

  .hero__badge {
    display: inline-block;
    padding: 0.375rem 0.875rem;
    background: rgba(249, 115, 22, 0.15);
    color: #ea580c;
    font-size: 0.875rem;
    font-weight: 600;
    border-radius: 9999px;
    margin-bottom: 1.5rem;
  }

  .hero__title {
    font-size: clamp(2rem, 5vw, 3.5rem);
    font-weight: 700;
    line-height: 1.2;
    margin: 0 0 1.5rem;
  }

  .hero__title-accent {
    color: #f97316;
  }

  .hero__description {
    font-size: 1.125rem;
    color: #666;
    max-width: 36rem;
    margin: 0 auto 2.5rem;
    line-height: 1.7;
  }

  .hero__actions {
    display: flex;
    flex-wrap: wrap;
    gap: 1rem;
    justify-content: center;
  }

  .hero__arrow {
    margin-left: 0.375rem;
  }

  .hero__code-icon {
    margin-right: 0.5rem;
    opacity: 0.8;
  }

  .stats {
    padding: 4rem 0;
    border-top: 1px solid #eee;
  }

  .stats__grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
    gap: 2rem;
    text-align: center;
  }

  .stats__item {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }

  .stats__value {
    font-size: 2.5rem;
    font-weight: 700;
    color: #1a1a1a;
  }

  .stats__label {
    font-size: 1rem;
    color: #666;
  }

  .why-choose {
    padding: 5rem 0;
    border-top: 1px solid #eee;
    text-align: center;
  }

  .why-choose__title {
    font-size: 2rem;
    font-weight: 700;
    margin: 0 0 1rem;
  }

  .why-choose__text {
    font-size: 1.125rem;
    color: #666;
    max-width: 32rem;
    margin: 0 auto;
    line-height: 1.7;
  }

  .section-title {
    font-size: 1.75rem;
    font-weight: 700;
    margin: 0 0 1rem;
    text-align: center;
  }

  .quick-start {
    padding: 5rem 0;
    border-top: 1px solid #eee;
  }

  .quick-start__text {
    font-size: 1.125rem;
    color: #666;
    text-align: center;
    margin: 0 0 1.5rem;
  }

  .quick-start__code {
    max-width: 36rem;
    margin: 0 auto;
    background: #1a1a1a;
    color: #e5e5e5;
    border-radius: 0.5rem;
    padding: 1.25rem 1.5rem;
    overflow-x: auto;
  }

  .quick-start__code pre {
    margin: 0;
    font-family: ui-monospace, monospace;
    font-size: 0.875rem;
    line-height: 1.6;
  }

  .quick-start__code code {
    white-space: pre-wrap;
    word-break: break-all;
  }

  .endpoints {
    padding: 5rem 0;
    border-top: 1px solid #eee;
  }

  .endpoints__intro {
    font-size: 1.125rem;
    color: #666;
    text-align: center;
    margin: 0 0 2rem;
  }

  .endpoints__list {
    max-width: 32rem;
    margin: 0 auto;
    padding: 0;
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
  }

  .endpoints__list li {
    padding: 0.75rem 1rem;
    background: #f8f8f8;
    border-radius: 0.375rem;
    font-size: 1rem;
  }

  .endpoints__list strong {
    color: var(--color-accent);
    margin-right: 0.5rem;
  }

  .cta {
    padding: 5rem 0 6rem;
    border-top: 1px solid #eee;
    text-align: center;
  }

  .cta__title {
    font-size: 1.75rem;
    font-weight: 700;
    margin: 0 0 0.5rem;
  }

  .cta__text {
    font-size: 1.125rem;
    color: #666;
    margin: 0 0 1.5rem;
  }

  @media (max-width: 768px) {
    .hero {
      padding: 3rem 0 4rem;
    }

    .hero__actions {
      flex-direction: column;
    }

    .hero__actions .btn {
      width: 100%;
      justify-content: center;
    }

    .stats {
      padding: 3rem 0;
    }

    .stats__grid {
      gap: 1.5rem;
    }

    .stats__value {
      font-size: 2rem;
    }

    .why-choose,
    .quick-start,
    .endpoints {
      padding: 3rem 0;
    }

    .quick-start__code {
      padding: 1rem;
    }

    .quick-start__code code {
      font-size: 0.8125rem;
    }

    .cta {
      padding: 3rem 0 4rem;
    }
  }
</style>
