---
import PublicPagesLayout from '@layouts/PublicPagesLayout.astro';
import { i18nService } from '@services/i18n';
import { getCollection } from 'astro:content';
import { getRelativeLocaleUrl } from 'astro:i18n';
import { type Locale } from 'src/types';

export async function getStaticPaths() {
  const collection = await getCollection('home');
  return collection.map((item) => ({
    params: { lang: i18nService.collectionIdToLocale(item.id) },
    props: item,
  }));
}
const lang = Astro.currentLocale as Locale;
const page = Astro.props;
const pageData = page.data;
---

<PublicPagesLayout title={pageData.title} description={pageData.description}>
  <main>
    <section class="hero">
      <div class="container">
        <span class="hero__badge">{pageData.theMostCompleteBitcoinAPI}</span>
        <h1 class="hero__title">
          {pageData.bitcoinAPIBuiltFor}
          <span class="hero__title-accent">{pageData.developers}</span>
        </h1>
        <p class="hero__description">{pageData.accessComprehensiveBitcoinDataWithTheMostComfortableAPI}</p>
        <div class="hero__actions">
          <a href={getRelativeLocaleUrl(lang, '/signup')} class="btn btn--primary">
            {pageData.startBuilding}
            <span class="hero__arrow">→</span>
          </a>
          <a href={getRelativeLocaleUrl(lang, '/docs')} class="btn btn--secondary">
            <span class="hero__code-icon">&lt;/&gt;</span>
            {pageData.viewDocumentation}
          </a>
        </div>
      </div>
    </section>

    <section class="stats">
      <div class="container">
        <div class="stats__grid">
          <div class="stats__item">
            <span class="stats__value">{pageData.uptime}</span>
            <span class="stats__label">{pageData.responseTime}</span>
          </div>
        </div>
      </div>
    </section>

    <section class="why-choose">
      <div class="container">
        <h2 class="why-choose__title">{pageData.whyChooseBitcoinAPI}</h2>
        <ul class="why-choose__list">
          <li class="why-choose__item">{pageData.convenientAPI}</li>
          <li class="why-choose__item">{pageData.detailedEndpointDocumentation}</li>
          <li class="why-choose__item">{pageData.wideVarietyOfData}</li>
          <li class="why-choose__item">{pageData.payOnlyForEndpointGroupsYouNeed}</li>
          <li class="why-choose__item">{pageData.mcpWithDocumentationForAI}</li>
        </ul>
      </div>
    </section>

    <section class="quick-start">
      <div class="container">
        <h2 class="section-title">{pageData.quickStart}</h2>
        <p class="quick-start__text">{pageData.getBitcoinDataInSeconds}</p>
        <div class="quick-start__code">
          <pre><code>{pageData.curlExample}</code></pre>
        </div>
      </div>
    </section>

    <section class="endpoints">
      <div class="container">
        <h2 class="section-title">{pageData.apiEndpoints}</h2>
        <p class="endpoints__intro">{pageData.comprehensiveDataAcrossTheBitcoinEcosystem}</p>
        <ul class="endpoints__list">
          {
            <li>
              <strong>{pageData.blocks}</strong> — {pageData.latestBlocksBlockDetailsOrphanBlocks}
            </li>
            <li>
              <strong>{pageData.mempool}</strong> — {pageData.unconfirmedTransactionsFees}
            </li>
            <li>
              <strong>{pageData.addresses}</strong> — {pageData.balanceHistoryUtxos}
            </li>
            <li>
              <strong>{pageData.transactions}</strong> — {pageData.decodeBroadcastFeeEstimates}
            </li>
          }
        </ul>
      </div>
    </section>

    <section class="cta">
      <div class="container">
        <h2 class="cta__title">{pageData.readyToBuild}</h2>
        <p class="cta__text">{pageData.startWithAFreeApiKey}</p>
        <a href={getRelativeLocaleUrl(lang, '/signup')} class="btn btn--primary">
          {pageData.getYourApiKey}
          <span class="hero__arrow">→</span>
        </a>
      </div>
    </section>
  </main>
</PublicPagesLayout>

<style lang="scss">
  .container {
    max-width: 1200px;
    margin: 0 auto;
    padding: 0 1.5rem;
  }

  .hero {
    padding: 5rem 0 6rem;
    text-align: center;
  }

  .hero__badge {
    display: inline-block;
    padding: 0.375rem 0.875rem;
    background: rgba(249, 115, 22, 0.15);
    color: #ea580c;
    font-size: 0.875rem;
    font-weight: 600;
    border-radius: 9999px;
    margin-bottom: 1.5rem;
  }

  .hero__title {
    font-size: clamp(2rem, 5vw, 3.5rem);
    font-weight: 700;
    line-height: 1.2;
    margin: 0 0 1.5rem;
  }

  .hero__title-accent {
    color: #f97316;
  }

  .hero__description {
    font-size: 1.125rem;
    color: #666;
    max-width: 36rem;
    margin: 0 auto 2.5rem;
    line-height: 1.7;
  }

  .hero__actions {
    display: flex;
    flex-wrap: wrap;
    gap: 1rem;
    justify-content: center;
  }

  .hero__arrow {
    margin-left: 0.375rem;
  }

  .hero__code-icon {
    margin-right: 0.5rem;
    opacity: 0.8;
  }

  .stats {
    padding: 4rem 0;
    border-top: 1px solid #eee;
  }

  .stats__grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
    gap: 2rem;
    text-align: center;
  }

  .stats__item {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }

  .stats__value {
    font-size: 2.5rem;
    font-weight: 700;
    color: #1a1a1a;
  }

  .stats__label {
    font-size: 1rem;
    color: #666;
  }

  .why-choose {
    padding: 5rem 0;
    border-top: 1px solid #eee;
    text-align: center;
  }

  .why-choose__title {
    font-size: 2rem;
    font-weight: 700;
    margin: 0 0 1rem;
  }

  .why-choose__list {
    list-style: none;
    padding: 0;
    margin: 0 auto;
    max-width: 28rem;
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
  }

  .why-choose__item {
    font-size: 1.125rem;
    color: #444;
    line-height: 1.6;
    padding-left: 1.5rem;
    position: relative;
  }

  .why-choose__item::before {
    content: '✓';
    position: absolute;
    left: 0;
    color: #22c55e;
    font-weight: 700;
  }

  .section-title {
    font-size: 1.75rem;
    font-weight: 700;
    margin: 0 0 1rem;
    text-align: center;
  }

  .quick-start {
    padding: 5rem 0;
    border-top: 1px solid #eee;
  }

  .quick-start__text {
    font-size: 1.125rem;
    color: #666;
    text-align: center;
    margin: 0 0 1.5rem;
  }

  .quick-start__code {
    max-width: 36rem;
    margin: 0 auto;
    background: #1a1a1a;
    color: #e5e5e5;
    border-radius: 0.5rem;
    padding: 1.25rem 1.5rem;
    overflow-x: auto;
  }

  .quick-start__code pre {
    margin: 0;
    font-family: ui-monospace, monospace;
    font-size: 0.875rem;
    line-height: 1.6;
  }

  .quick-start__code code {
    white-space: pre-wrap;
    word-break: break-all;
  }

  .endpoints {
    padding: 5rem 0;
    border-top: 1px solid #eee;
  }

  .endpoints__intro {
    font-size: 1.125rem;
    color: #666;
    text-align: center;
    margin: 0 0 2rem;
  }

  .endpoints__list {
    max-width: 32rem;
    margin: 0 auto;
    padding: 0;
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
  }

  .endpoints__list li {
    padding: 0.75rem 1rem;
    background: #f8f8f8;
    border-radius: 0.375rem;
    font-size: 1rem;
  }

  .endpoints__list strong {
    color: var(--color-accent);
    margin-right: 0.5rem;
  }

  .cta {
    padding: 5rem 0 6rem;
    border-top: 1px solid #eee;
    text-align: center;
  }

  .cta__title {
    font-size: 1.75rem;
    font-weight: 700;
    margin: 0 0 0.5rem;
  }

  .cta__text {
    font-size: 1.125rem;
    color: #666;
    margin: 0 0 1.5rem;
  }

  @media (max-width: 768px) {
    .hero {
      padding: 3rem 0 4rem;
    }

    .hero__actions {
      flex-direction: column;
    }

    .hero__actions .btn {
      width: 100%;
      justify-content: center;
    }

    .stats {
      padding: 3rem 0;
    }

    .stats__grid {
      gap: 1.5rem;
    }

    .stats__value {
      font-size: 2rem;
    }

    .why-choose,
    .quick-start,
    .endpoints {
      padding: 3rem 0;
    }

    .quick-start__code {
      padding: 1rem;
    }

    .quick-start__code code {
      font-size: 0.8125rem;
    }

    .cta {
      padding: 3rem 0 4rem;
    }
  }
</style>
